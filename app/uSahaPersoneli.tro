  // ============================ [SNIPPET: uRtdb] ===============================

  // ============================ [SNIPPET: Session] =============================
  // Clomosy.GlobalVariableString TEK scalar slot. Coklu key icin pipe ayrim:
  //   |Token=...|UserId=...|AdSoyad=...|

  function SessionGet(key : String) : String;
  var
    s, marker, rest : String;
  {
    s = Clomosy.GlobalVariableString;
    marker = '|' + key + '=';
    if (Pos(marker, s) > 0)
    {
      rest = clGetStringAfter(s, marker);
      Result = clGetStringTo(rest, '|');
    }
    else
    {
      Result = '';
    }
  }

  void SessionSet(key : String; value : String);
  var
    s, marker, before, rest, after : String;
  {
    s = Clomosy.GlobalVariableString;
    if (s == '')
    {
      s = '|';
    }
    if (Copy(s, 1, 1) <> '|')
    {
      s = '|' + s;
    }
    if (Copy(s, Length(s), 1) <> '|')
    {
      s = s + '|';
    }

    marker = '|' + key + '=';
    if (Pos(marker, s) > 0)
    {
      before = clGetStringTo(s, marker);
      rest   = clGetStringAfter(s, marker);
      after  = clGetStringAfter(rest, '|');
      s = before + marker + value + '|' + after;
    }
    else
    {
      s = s + key + '=' + value + '|';
    }

    Clomosy.GlobalVariableString = s;
  }

  void SessionClear;
  {
    Clomosy.GlobalVariableString = '';
  }


  function DbUrl : String;
  var u : String;
  {
    u = SessionGet('DbUrl');
    if (u == '')
    {
      Result = 'https://akilli-ariza-saha-default-rtdb.europe-west1.firebasedatabase.app';
    }
    else
    {
      Result = u;
    }
  }

  function Token : String;
  {
    Result = SessionGet('Token');
  }

  function AuthQuery : String;
  {
    Result = 'auth=' + Token;
  }

  function RtdbUrl(Path : String; ExtraQuery : String) : String;
  var q : String;
  {
    q = AuthQuery;
    if (ExtraQuery <> '')
    {
      q = q + '&' + ExtraQuery;
    }
    Result = DbUrl + '/' + Path + '.json?' + q;
  }

  function JsonEsc(S : String) : String;
  var R : String;
  {
    R = clGetStringReplace(S, '\', '\\');
    R = clGetStringReplace(R, '"', '\"');
    R = clGetStringReplace(R, Chr(13), '');
    R = clGetStringReplace(R, Chr(10), ' ');
    Result = R;
  }

  function RtdbGet(Path : String; Query : String) : String;
  var
    R   : TclRest;
    url : String;
  {
    url = RtdbUrl(Path, Query);
    SessionSet('LastReqUrl', url);
    R = TclRest.Create;
    try
      R.BaseURL = url;
      R.Method  = rmGET;
      R.Accept  = 'application/json';
      R.Execute;
      Result = R.Response;
    finally
      R.Free;
    }
  }

  function RtdbPost(Path : String; BodyJson : String) : String;
  var R : TclRest;
  {
    R = TclRest.Create;
    try
      R.BaseURL     = RtdbUrl(Path, '');
      R.Method      = rmPOST;
      R.Accept      = 'application/json';
      R.ContentType = 'application/json';
      R.Body        = BodyJson;
      R.Execute;
      Result = R.Response;
    finally
      R.Free;
    }
  }

  function RtdbPatch(Path : String; BodyJson : String) : String;
  var R : TclRest;
  {
    R = TclRest.Create;
    try
      R.BaseURL     = RtdbUrl(Path, '');
      R.Method      = rmPATCH;
      R.Accept      = 'application/json';
      R.ContentType = 'application/json';
      R.Body        = BodyJson;
      R.Execute;
      Result = R.Response;
    finally
      R.Free;
    }
  }

  function JsonStrAlan(Json : String; Alan : String) : String;
  var
    marker : String;
    s      : String;
  {
    marker = '"' + Alan + '"';
    if (Pos(marker, Json) == 0)
    {
      Result = '';
    }
    else
    {
      s = clGetStringAfter(Json, marker);
      s = clGetStringAfter(s, ':');
      s = clGetStringAfter(s, '"');
      Result = clGetStringTo(s, '"');
    }
  }

  function NowIso : String;
  {
    Result = FormatDateTime('yyyy-mm-dd"T"hh:nn:ss"Z"', Now);
  }


  function IMin(a, b : Integer) : Integer;
  {
    if (a < b)
    {
      Result = a;
    }
    else
    {
      Result = b;
    }
  }

  function IMax(a, b : Integer) : Integer;
  {
    if (a > b)
    {
      Result = a;
    }
    else
    {
      Result = b;
    }
  }


  void GorevListeGorunum(listeDolu : Boolean);
  {
    if (listeDolu)
    {
      LbGorevler.Visible = True;
      PnlEmptyState.Visible = False;
      LbGorevler.BringToFront;
    }
    else
    {
      LbGorevler.Visible = False;
      PnlEmptyState.Visible = True;
    }
  }


  void GorevListeDesignerRenkYenile;
  {
    if (LvDesigner <> nil)
    {
      LvDesigner.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
      LvDesigner.SetclProSettings(LvDesigner.clProSettings);
    }
    if (LvLMain <> nil)
    {
      LvLMain.clProSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
      LvLMain.clProSettings.TextSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
      LvLMain.clProSettings.IsTransparent = False;
      LvLMain.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
      LvLMain.SetclProSettings(LvLMain.clProSettings);
    }
    if (LvLSub <> nil)
    {
      LvLSub.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
      LvLSub.clProSettings.TextSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
      LvLSub.clProSettings.IsTransparent = False;
      LvLSub.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
      LvLSub.SetclProSettings(LvLSub.clProSettings);
    }
    if (LvLFoot <> nil)
    {
      LvLFoot.clProSettings.FontColor = clAlphaColor.clHexToColor(C_PRIMARY);
      LvLFoot.clProSettings.TextSettings.FontColor = clAlphaColor.clHexToColor(C_PRIMARY);
      LvLFoot.clProSettings.IsTransparent = False;
      LvLFoot.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
      LvLFoot.SetclProSettings(LvLFoot.clProSettings);
    }
  }


  void GorevListesiYukle(json : String; filtre : String);
  var
    rem, key, blok : String;
    baslangic, adet : Integer;
    ticketNo, baslik, durum : String;
    konum, oncelik : String;
    arr : String;
    hay : String;
    ned : String;
    ilk : Boolean;
    gec : Boolean;
    depth, idx : Integer;
    ch : String;
    inStr, esc : Boolean;
  {
    arr = '[';
    ilk = True;
    adet = 0;
    ned = Trim(filtre);

    if ((json == '') || (json == 'null') || (json == '{}'))
    {
      LbGorevler.ClearList;
      GorevListeGorunum(False);
      LblGorevCount.Text = '0 gorev';
      Exit;
    }

    rem = json;
    while (Pos('":{', rem) > 0)
    {
      baslangic = Pos('"', rem);
      if (baslangic == 0) { break; }
      rem = Copy(rem, baslangic + 1, Length(rem));

      key = clGetStringTo(rem, '":{');
      rem = clGetStringAfter(rem, '":{');

      depth = 1;
      idx   = 1;
      inStr = False;
      esc   = False;
      while ((idx <= Length(rem)) && (depth > 0))
      {
        ch = Copy(rem, idx, 1);
        if (esc == True)
        {
          esc = False;
        }
        else if (ch == Chr(92))
        {
          esc = True;
        }
        else if (ch == '"')
        {
          inStr = (inStr == False);
        }
        else if (inStr == False)
        {
          if      (ch == '{') { depth = depth + 1; }
          else if (ch == '}') { depth = depth - 1; }
        }
        idx = idx + 1;
      }
      blok = Copy(rem, 1, idx - 2);
      rem  = Copy(rem, idx, Length(rem));

      ticketNo = JsonStrAlan('{' + blok + '}', 'ticketNo');
      baslik   = JsonStrAlan('{' + blok + '}', 'baslik');
      durum    = JsonStrAlan('{' + blok + '}', 'durum');
      konum    = JsonStrAlan('{' + blok + '}', 'konum');
      oncelik  = JsonStrAlan('{' + blok + '}', 'oncelik');

      if (durum <> 'Tamamlandi')
      {
        gec = True;
        if (ned <> '')
        {
          hay = AnsiLowerCase(ticketNo + ' ' + baslik + ' ' + konum + ' ' + oncelik);
          if (Pos(AnsiLowerCase(ned), hay) == 0)
          {
            gec = False;
          }
        }
        if (gec == True)
        {
          if (ilk == False) { arr = arr + ','; }
          arr = arr + '{"MAIN_TEXT":"' + JsonEsc(ticketNo + ' - ' + baslik) + '",' +
            '"SUB_TEXT":"' + JsonEsc(konum + '  |  ' + oncelik) + '",' +
            '"FOOTER_TEXT":"' + JsonEsc(durum) + '",' +
            '"RECORD_GUID":"' + key + '"}';
          ilk = False;
          adet = adet + 1;
        }
      }
    }

    if (ilk == False)
    {
      arr = arr + ']';
      LbGorevler.clLoadProListViewDataFromDataset(Clomosy.ClDataSetFromJSON(arr));
      GorevListeGorunum(True);
      GorevListeDesignerRenkYenile;
      LbGorevler.SetclProSettings(LbGorevler.clProSettings);
      LblGorevCount.Text = IntToStr(adet) + ' gorev';
    }
    else
    {
      LbGorevler.ClearList;
      GorevListeGorunum(False);
      LblGorevCount.Text = '0 gorev';
    }
  }


  void YerlesimLayoutIste;
  {
    if (TmrYerlesim <> nil)
    {
      TmrYerlesim.Enabled = True;
    }
  }


  void GorevAramaDegisti;
  {
    if (LastGorevJson == '')
    {
      Exit;
    }
    GorevListesiYukle(LastGorevJson, Trim(EdtGorevAra.Text));
    YerlesimLayoutIste;
  }


  // Bos mesaj satiri yer kaplamasin.
  void LblMsgBoslukAyarla;
  {
    if (Trim(LblMsg.Text) == '')
    {
      LblMsg.Visible = False;
      LblMsg.Height = 0;
      LblMsg.Margins.Top = 0;
      LblMsg.Margins.Bottom = 0;
      LblMsg.Align = alTop;
    }
    else
    {
      LblMsg.Visible = True;
      LblMsg.Align = alTop;
      LblMsg.Height = 48;
      LblMsg.Margins.Top = 10;
      LblMsg.Margins.Bottom = 12;
      LblMsg.clProSettings.WordWrap = True;
      LblMsg.clProSettings.FontVertAlign = palCenter;
      LblMsg.SetclProSettings(LblMsg.clProSettings);
    }
  }


  void UygulaResponsiveSaha;
  var
    rawW    : Integer;
    narrow  : Boolean;
    sideM   : Integer;
    innerW  : Integer;
    listH   : Integer;
    kartL   : Integer;
    aksH    : Integer;
    bodyH   : Integer;
    btnH    : Integer;
    btnGap  : Integer;
  {
    rawW = FormP.clWidth;
    narrow = (rawW > 250) && (rawW < C_BREAK_NARROW);

    if (narrow)
    {
      sideM = 8;
      PnlBody.Margins.Left   = sideM;
      PnlBody.Margins.Right  = sideM;
      PnlBody.Margins.Top    = 8;
      PnlBody.Margins.Bottom = 8;
    }
    else
    {
      sideM = 12;
      PnlBody.Margins.Left   = sideM;
      PnlBody.Margins.Right  = sideM;
      PnlBody.Margins.Top    = 12;
      PnlBody.Margins.Bottom = 12;
    }

    innerW = rawW - PnlBody.Margins.Left - PnlBody.Margins.Right;
    innerW = IMax(innerW, 280);

    LblBaslik.Width = IMin(220, IMax(160, innerW div 2));

    if (narrow)
    {
      BtnCikis.Width = 72;
    }
    else
    {
      BtnCikis.Width = 80;
    }

    listH = Round(FormP.clHeight * 0.33);
    listH = IMax(listH, 228);
    listH = IMin(listH, 392);
    PnlListHost.Height = listH;

    kartL = 172 + listH + 20;
    PnlKartListe.Height = kartL;

    // Durum karti: ust blok + 4 tam genislik dugme (dikey) + mesaj.
    aksH = 458;
    if (Trim(LblMsg.Text) <> '')
    {
      aksH = 528;
    }
    PnlKartAksiyon.Height = aksH;

    bodyH = kartL + 12 + aksH + PnlBody.Margins.Top + PnlBody.Margins.Bottom + C_SAFE_BOTTOM + 16;
    bodyH = IMax(bodyH, FormP.clHeight - 58 + C_SAFE_BOTTOM);
    bodyH = IMax(bodyH, 640);
    PnlBody.Height = bodyH;

    PnlSolToolbar.Height = 54;
    if (innerW < 340)
    {
      PnlToolPrefix.Width = 72;
    }
    else
    {
      PnlToolPrefix.Width = 104;
    }

    if (innerW < 340)
    {
      EdtGorevAra.clProSettings.FontSize = 11;
      EdtGorevAra.SetclProSettings(EdtGorevAra.clProSettings);
      EdtGorevAra.TextPrompt = 'Numara, baslik veya konum';
      BtnGorevAra.clProSettings.FontSize = 11;
      BtnGorevAra.SetclProSettings(BtnGorevAra.clProSettings);
    }
    else
    {
      EdtGorevAra.clProSettings.FontSize = 13;
      EdtGorevAra.SetclProSettings(EdtGorevAra.clProSettings);
      EdtGorevAra.TextPrompt = 'Numara, baslik veya konum';
      BtnGorevAra.clProSettings.FontSize = 12;
      BtnGorevAra.SetclProSettings(BtnGorevAra.clProSettings);
    }

    if (narrow)
    {
      btnH = 46;
      btnGap = 8;
    }
    else
    {
      btnH = 48;
      btnGap = 10;
    }

    BtnYolda.Height = btnH;
    BtnIslemde.Height = btnH;
    BtnBeklemede.Height = btnH;
    BtnTamam.Height = btnH;

    BtnYolda.Margins.Top = 12;
    BtnIslemde.Margins.Top = btnGap;
    BtnBeklemede.Margins.Top = btnGap;
    BtnTamam.Margins.Top = btnGap;

    LblMsg.Margins.Top = 12;

    LblMsgBoslukAyarla;

    if (LvDesigner <> nil)
    {
      LvDesigner.Width = IMax(200, innerW - 64);
      LvDesigner.SetclProSettings(LvDesigner.clProSettings);
    }
    GorevListeDesignerRenkYenile;
  }


  void YerlesimLayoutTick;
  {
    UygulaResponsiveSaha;
    TmrYerlesim.Enabled = False;
  }


  // ========================= [DURUM GECIS KURALLARI] ===========================
  // Gecerli gecisler:
  //   Atandi    -> Yolda
  //   Atandi    -> Islemde       (yerinde mudahale, yola cikma gerekmez)
  //   Yolda     -> Islemde
  //   Islemde   -> Beklemede
  //   Islemde   -> Tamamlandi
  //   Beklemede -> Islemde
  //   Beklemede -> Tamamlandi    (beklemeden tamamlanabilir)

  function GecisGecerli(eski : String; yeni : String) : Boolean;
  {
    if      ((eski == 'Atandi')    && (yeni == 'Yolda'))      { Result = True; }
    else if ((eski == 'Atandi')    && (yeni == 'Islemde'))    { Result = True; }
    else if ((eski == 'Yolda')     && (yeni == 'Islemde'))    { Result = True; }
    else if ((eski == 'Islemde')   && (yeni == 'Beklemede'))  { Result = True; }
    else if ((eski == 'Islemde')   && (yeni == 'Tamamlandi')) { Result = True; }
    else if ((eski == 'Beklemede') && (yeni == 'Islemde'))    { Result = True; }
    else if ((eski == 'Beklemede') && (yeni == 'Tamamlandi')) { Result = True; }
    else                                                       { Result = False; }
  }


  // =========================== [EVENT HANDLERS] ================================

  void GorevleriYenile;
  var
    uid  : String;
    json : String;
  {
    uid = SessionGet('UserId');
    if (uid == '')
    {
      ShowMessage('Oturum yok');
      Clomosy.RunUnit('uLogin');
      FormP.clHide;
    }
    else
    {
      try
        json = RtdbGet('tickets', 'orderBy="atananPersonelId"&equalTo="' + uid + '"');
        SessionSet('LastReqResp', json);
        LastGorevJson = json;
        try
          GorevListesiYukle(json, Trim(EdtGorevAra.Text));
          LblSecili.Text = 'Gorev secilmedi';
          LblDurum.Text  = '';
          LblSecili.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
          LblSecili.SetclProSettings(LblSecili.clProSettings);
        except
          LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
          LblMsg.SetclProSettings(LblMsg.clProSettings);
          LblMsg.Text = 'Liste hatasi: ' + LastExceptionMessage;
        }
      except
        LastGorevJson = '';
        LbGorevler.ClearList;
        GorevListeGorunum(False);
        LblGorevCount.Text = '0 gorev';
        LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
        LblMsg.SetclProSettings(LblMsg.clProSettings);
        LblMsg.Text = 'Listeleme (RTDB): ' + LastExceptionMessage;
      }
    }
    YerlesimLayoutIste;
  }


  void GorevleriYenileBaslat;
  {
    LblMsg.Text = '';
    LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LblMsg.SetclProSettings(LblMsg.clProSettings);
    GorevleriYenile;
  }


  void GorevSecildi;
  var cap, sub_, dur : String;
  {
    cap   = LbGorevler.clSelectedItemData(clCaption);
    sub_  = LbGorevler.clSelectedItemData(clText);
    dur   = LbGorevler.clSelectedItemData(clText1);
    if (cap <> '')
    {
      LblSecili.Text = 'Secilen: ' + cap;
      LblDurum.Text  = 'Mevcut durum: ' + dur;
      LblSecili.clProSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
      LblSecili.SetclProSettings(LblSecili.clProSettings);
      if (sub_ <> '')
      {
        LblDurum.Text = LblDurum.Text + Chr(10) + sub_;
      }
    }
  }


  // Tek bir geciste calisacak genel gunceller.

  void DurumDegistir(yeniDurum : String);
  var
    ticketId   : String;
    eskiDurum  : String;
    uid        : String;
    not_       : String;
    now_       : String;
    body, ev   : String;
  {
    LblMsg.Text = '';
    LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LblMsg.SetclProSettings(LblMsg.clProSettings);

    ticketId  = LbGorevler.clSelectedItemData(clRecord_GUID);
    eskiDurum = LbGorevler.clSelectedItemData(clText1);

    if (ticketId == '')
    {
      LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
      LblMsg.SetclProSettings(LblMsg.clProSettings);
      LblMsg.Text = 'Lutfen bir gorev secin';
      YerlesimLayoutIste;
      Exit;
    }

    if (not GecisGecerli(eskiDurum, yeniDurum))
    {
      LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
      LblMsg.SetclProSettings(LblMsg.clProSettings);
      LblMsg.Text = eskiDurum + ' -> ' + yeniDurum + ' gecisi gecerli degil';
      YerlesimLayoutIste;
      Exit;
    }

    uid  = SessionGet('UserId');
    not_ = Trim(EdtNot.Text);
    now_ = NowIso;

    body = '{' +
      '"durum":"'      + yeniDurum + '",' +
      '"updatedAt":"'  + now_      + '"' +
    '}';

    try
      RtdbPatch('tickets/' + ticketId, body);

      ev = '{' +
        '"fromStatus":"' + eskiDurum + '",' +
        '"toStatus":"'   + yeniDurum + '",' +
        '"changedBy":"'  + uid + '",' +
        '"changedAt":"'  + now_ + '",' +
        '"note":"'       + JsonEsc(not_) + '"' +
      '}';
      RtdbPost('tickets/' + ticketId + '/events', ev);

      LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_SUCCESS);
      LblMsg.SetclProSettings(LblMsg.clProSettings);
      LblMsg.Text = 'Durum guncellendi: ' + yeniDurum;
      EdtNot.Text = '';
      GorevleriYenile;
    except
      LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
      LblMsg.SetclProSettings(LblMsg.clProSettings);
      LblMsg.Text = 'Guncelleme hatasi: ' + LastExceptionMessage;
      YerlesimLayoutIste;
    }
  }

  void YoldaClick;       { DurumDegistir('Yolda');      }
  void IslemdeClick;     { DurumDegistir('Islemde');    }
  void BeklemedeClick;   { DurumDegistir('Beklemede');  }
  void TamamlandiClick;  { DurumDegistir('Tamamlandi'); }

  void CikisClick;
  {
    SessionClear;
    Clomosy.RunUnit('uLogin');
    FormP.clHide;
  }


