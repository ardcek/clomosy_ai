    C_MUTED       = '#64748B';
    C_ON_SOLID    = '#FFFFFF';
    C_HEADER_BAR  = '#EFF6FF';
    C_MUTED_BG    = '#EEF2FF';
    C_BODY_END    = '#E8EDF5';
    C_BREAK_NARROW = 760;
    C_SAFE_BOTTOM  = 40;
    C_BTN_YOLDA    = '#0891B2';
    C_BTN_ISLEM    = '#F59E0B';
    C_BTN_BEK      = '#64748B';
    C_BTN_TAMAM    = '#10B981';


