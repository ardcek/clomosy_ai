// ============================ [SNIPPET: uRtdb] ===============================

// ============================ [SNIPPET: Session] =============================
// Clomosy.GlobalVariableString TEK scalar slot. Coklu key icin pipe ayrim:
//   |Token=...|UserId=...|AdSoyad=...|

function SessionGet(key : String) : String;
var
  s, marker, rest : String;
{
  s = Clomosy.GlobalVariableString;
  marker = '|' + key + '=';
  if (Pos(marker, s) > 0)
  {
    rest = clGetStringAfter(s, marker);
    Result = clGetStringTo(rest, '|');
  }
  else
  {
    Result = '';
  }
}

void SessionSet(key : String; value : String);
var
  s, marker, before, rest, after : String;
{
  s = Clomosy.GlobalVariableString;
  if (s == '')
  {
    s = '|';
  }
  if (Copy(s, 1, 1) <> '|')
  {
    s = '|' + s;
  }
  if (Copy(s, Length(s), 1) <> '|')
  {
    s = s + '|';
  }

  marker = '|' + key + '=';
  if (Pos(marker, s) > 0)
  {
    before = clGetStringTo(s, marker);
    rest   = clGetStringAfter(s, marker);
    after  = clGetStringAfter(rest, '|');
    s = before + marker + value + '|' + after;
  }
  else
  {
    s = s + key + '=' + value + '|';
  }

  Clomosy.GlobalVariableString = s;
}

void SessionClear;
{
  Clomosy.GlobalVariableString = '';
}


function DbUrl : String;
var u : String;
{
  u = SessionGet('DbUrl');
  if (u == '')
  {
    Result = 'https://akilli-ariza-saha-default-rtdb.europe-west1.firebasedatabase.app';
  }
  else
  {
    Result = u;
  }
}

function Token : String;
{
  Result = SessionGet('Token');
}

function AuthQuery : String;
{
  Result = 'auth=' + Token;
}

function RtdbUrl(Path : String; ExtraQuery : String) : String;
var q : String;
{
  q = AuthQuery;
  if (ExtraQuery <> '')
  {
    q = q + '&' + ExtraQuery;
  }
  Result = DbUrl + '/' + Path + '.json?' + q;
}

function JsonEsc(S : String) : String;
var R : String;
{
  R = clGetStringReplace(S, '\', '\\');
  R = clGetStringReplace(R, '"', '\"');
  R = clGetStringReplace(R, Chr(13), '');
  R = clGetStringReplace(R, Chr(10), ' ');
  Result = R;
}

function RtdbGet(Path : String; Query : String) : String;
var
  R   : TclRest;
  url : String;
{
  url = RtdbUrl(Path, Query);
  SessionSet('LastReqUrl', url);
  R = TclRest.Create;
  try
    R.BaseURL = url;
    R.Method  = rmGET;
    R.Accept  = 'application/json';
    R.Execute;
    Result = R.Response;
  finally
    R.Free;
  }
}

function RtdbPost(Path : String; BodyJson : String) : String;
var R : TclRest;
{
  R = TclRest.Create;
  try
    R.BaseURL     = RtdbUrl(Path, '');
    R.Method      = rmPOST;
    R.Accept      = 'application/json';
    R.ContentType = 'application/json';
    R.Body        = BodyJson;
    R.Execute;
    Result = R.Response;
  finally
    R.Free;
  }
}

function JsonStrAlan(Json : String; Alan : String) : String;
var
  marker : String;
  s      : String;
{
  marker = '"' + Alan + '"';
  if (Pos(marker, Json) == 0)
  {
    Result = '';
  }
  else
  {
    s = clGetStringAfter(Json, marker);
    s = clGetStringAfter(s, ':');
    s = clGetStringAfter(s, '"');
    Result = clGetStringTo(s, '"');
  }
}

function RtdbPostKeyOku(PostResp : String) : String;
{
  Result = JsonStrAlan(PostResp, 'name');
}


// ============================ [SLA HESAPLA] ==================================

function SlaSaatler(Oncelik : String) : Integer;
{
  if (Oncelik == 'Kritik')      { Result = 2;  }
  else if (Oncelik == 'Yuksek') { Result = 8;  }
  else if (Oncelik == 'Orta')   { Result = 24; }
  else                          { Result = 72; }
}

function SlaDeadline(Oncelik : String) : String;
var saat : Integer;
{
  saat = SlaSaatler(Oncelik);
  Result = FormatDateTime('yyyy-mm-dd"T"hh:nn:ss"Z"', Now + (saat / 24));
}

function NowIso : String;
{
  Result = FormatDateTime('yyyy-mm-dd"T"hh:nn:ss"Z"', Now);
}

function TicketNoUret : String;
var d : String;
{
  d = FormatDateTime('yymmddhhnnss', Now);
  Result = 'ARZ-' + d;
}


function IMin(a, b : Integer) : Integer;
{
  if (a < b)
  {
    Result = a;
  }
  else
  {
    Result = b;
  }
}

function IMax(a, b : Integer) : Integer;
{
  if (a > b)
  {
    Result = a;
  }
  else
  {
    Result = b;
  }
}


// =========================== [LISTE] =========================================
// RTDB GET: {"-Nxxx":{"ticketNo":"...",...},...}
// ProListView: MAIN_TEXT ilk (clCaption baglantisinda bazi surumler ilk kolonu kullanir); RECORD_GUID son.

void TaleplerimListeGorunum(listeDolu : Boolean);
{
  if (listeDolu)
  {
    LbTalepler.Visible = True;
    PnlEmptyState.Visible = False;
    LbTalepler.BringToFront;
  }
  else
  {
    LbTalepler.Visible = False;
    PnlEmptyState.Visible = True;
  }
}

void TaleplerimListeDesignerRenkYenile;
{
  if (LvDesigner <> nil)
  {
    LvDesigner.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
    LvDesigner.SetclProSettings(LvDesigner.clProSettings);
  }
  if (LvLMain <> nil)
  {
    LvLMain.clProSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
    LvLMain.clProSettings.TextSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
    LvLMain.clProSettings.IsTransparent = False;
    LvLMain.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
    LvLMain.SetclProSettings(LvLMain.clProSettings);
  }
  if (LvLSub <> nil)
  {
    LvLSub.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LvLSub.clProSettings.TextSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LvLSub.clProSettings.IsTransparent = False;
    LvLSub.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
    LvLSub.SetclProSettings(LvLSub.clProSettings);
  }
  if (LvLFoot <> nil)
  {
    LvLFoot.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LvLFoot.clProSettings.TextSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LvLFoot.clProSettings.IsTransparent = False;
    LvLFoot.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
    LvLFoot.SetclProSettings(LvLFoot.clProSettings);
  }
}

void TaleplerimListesiYukle(json : String; filtre : String);
var
  rem, key, blok : String;
  baslangic, adet : Integer;
  ticketNo, baslik, durum : String;
  konum, oncelik, createdAt, footerSaat : String;
  arr : String;
  hay : String;
  ned : String;
  ilk : Boolean;
  gec : Boolean;
  depth, idx : Integer;
  ch : String;
  inStr, esc : Boolean;
{
  arr = '[';
  ilk = True;
  adet = 0;
  ned = Trim(filtre);

  if ((json == '') || (json == 'null') || (json == '{}'))
  {
    LbTalepler.ClearList;
    TaleplerimListeGorunum(False);
    LblTalepCount.Text = '0 talep';
    LblEmptyTitle.Text = 'Henuz talebiniz yok';
    LblEmptySub.Text =
      'Yenile ile listeyi guncelleyin. Arama kutusu ile filtreleyebilirsiniz.';
    LblEmptyTitle.SetclProSettings(LblEmptyTitle.clProSettings);
    LblEmptySub.SetclProSettings(LblEmptySub.clProSettings);
    Exit;
  }

  rem = json;
  while (Pos('":{', rem) > 0)
  {
    baslangic = Pos('"', rem);
    if (baslangic == 0) { break; }
    rem = Copy(rem, baslangic + 1, Length(rem));

    key = clGetStringTo(rem, '":{');
    rem = clGetStringAfter(rem, '":{');

    depth = 1;
    idx   = 1;
    inStr = False;
    esc   = False;
    while ((idx <= Length(rem)) && (depth > 0))
    {
      ch = Copy(rem, idx, 1);
      if (esc == True)
      {
        esc = False;
      }
      else if (ch == Chr(92))
      {
        esc = True;
      }
      else if (ch == '"')
      {
        inStr = (inStr == False);
      }
      else if (inStr == False)
      {
        if      (ch == '{') { depth = depth + 1; }
        else if (ch == '}') { depth = depth - 1; }
      }
      idx = idx + 1;
    }
    blok = Copy(rem, 1, idx - 2);
    rem  = Copy(rem, idx, Length(rem));

    ticketNo  = JsonStrAlan('{' + blok + '}', 'ticketNo');
    baslik    = JsonStrAlan('{' + blok + '}', 'baslik');
    durum     = JsonStrAlan('{' + blok + '}', 'durum');
    konum     = JsonStrAlan('{' + blok + '}', 'konum');
    oncelik   = JsonStrAlan('{' + blok + '}', 'oncelik');
    createdAt = JsonStrAlan('{' + blok + '}', 'createdAt');

    gec = True;
    if (ned <> '')
    {
      hay = AnsiLowerCase(ticketNo + ' ' + baslik + ' ' + konum + ' ' + oncelik + ' ' + durum);
      if (Pos(AnsiLowerCase(ned), hay) == 0)
      {
        gec = False;
      }
    }
    if (gec == True)
    {
      if (Length(createdAt) >= 16)
      {
        footerSaat = Copy(createdAt, 12, 5);
      }
      else if (createdAt <> '')
      {
        footerSaat = createdAt;
      }
      else
      {
        footerSaat = '--:--';
      }

      if (ilk == False) { arr = arr + ','; }
      arr = arr + '{"MAIN_TEXT":"' + JsonEsc(ticketNo + ' - ' + baslik) + '",' +
        '"SUB_TEXT":"' + JsonEsc(konum + '  |  ' + oncelik + '  |  ' + durum) + '",' +
        '"FOOTER_TEXT":"' + JsonEsc('Olusturuldu: ' + footerSaat) + '",' +
        '"RECORD_GUID":"' + key + '"}';
      ilk = False;
      adet = adet + 1;
    }
  }

  if (ilk == False)
  {
    arr = arr + ']';
    LbTalepler.clLoadProListViewDataFromDataset(Clomosy.ClDataSetFromJSON(arr));
    TaleplerimListeGorunum(True);
    TaleplerimListeDesignerRenkYenile;
    LbTalepler.SetclProSettings(LbTalepler.clProSettings);
    LblTalepCount.Text = IntToStr(adet) + ' talep';
  }
  else
  {
    LbTalepler.ClearList;
    TaleplerimListeGorunum(False);
    LblTalepCount.Text = '0 talep';
    if (ned <> '')
    {
      LblEmptyTitle.Text = 'Aramaya uygun sonuc yok';
      LblEmptySub.Text =
        'Arama metnini temizleyin veya Yenile ile tum listeyi gorun.';
    }
    else
    {
      LblEmptyTitle.Text = 'Henuz talebiniz yok';
      LblEmptySub.Text =
        'Yenile ile listeyi guncelleyin. Arama kutusu ile filtreleyebilirsiniz.';
    }
    LblEmptyTitle.SetclProSettings(LblEmptyTitle.clProSettings);
    LblEmptySub.SetclProSettings(LblEmptySub.clProSettings);
  }
}


void YerlesimLayoutIste;
{
  if (TmrYerlesim <> nil)
  {
    TmrYerlesim.Enabled = True;
  }
}

void TalepAramaDegisti;
{
  if (LastTalepimJson == '')
  {
    Exit;
  }
  TaleplerimListesiYukle(LastTalepimJson, Trim(EdtTalepAra.Text));
  YerlesimLayoutIste;
}


void LblForumMsgBoslukAyarla;
{
  if (Trim(LblForumMsg.Text) == '')
  {
    LblForumMsg.Visible = False;
    LblForumMsg.Height = 0;
    LblForumMsg.Margins.Top = 0;
    LblForumMsg.Margins.Bottom = 0;
  }
  else
  {
    LblForumMsg.Visible = True;
    LblForumMsg.Height = 44;
    LblForumMsg.Margins.Top = 10;
    LblForumMsg.Margins.Bottom = 12;
    LblForumMsg.clProSettings.WordWrap = True;
    LblForumMsg.SetclProSettings(LblForumMsg.clProSettings);
  }
}


void UygulaResponsiveTalepAcma;
var
  rawW    : Integer;
  narrow  : Boolean;
  sideM   : Integer;
  innerW  : Integer;
  listH   : Integer;
  kartL   : Integer;
  formK   : Integer;
  bodyH   : Integer;
{
  rawW = FormTA.clWidth;
  narrow = (rawW > 250) && (rawW < C_BREAK_NARROW);

  if (narrow)
  {
    sideM = 8;
    PnlBody.Margins.Left   = sideM;
    PnlBody.Margins.Right  = sideM;
    PnlBody.Margins.Top    = 8;
    PnlBody.Margins.Bottom = 8;
  }
  else
  {
    sideM = 12;
    PnlBody.Margins.Left   = sideM;
    PnlBody.Margins.Right  = sideM;
    PnlBody.Margins.Top    = 12;
    PnlBody.Margins.Bottom = 12;
  }

  innerW = rawW - PnlBody.Margins.Left - PnlBody.Margins.Right;
  innerW = IMax(innerW, 280);

  LblBaslik.Width = IMin(220, IMax(160, innerW div 2));

  if (narrow)
  {
    BtnCikis.Width = 72;
  }
  else
  {
    BtnCikis.Width = 80;
  }

  listH = Round(FormTA.clHeight * 0.33);
  listH = IMax(listH, 228);
  listH = IMin(listH, 392);
  PnlListHost.Height = listH;

  kartL = 172 + listH + 20;
  PnlKartListe.Height = kartL;

  LblForumMsgBoslukAyarla;
  formK = 458;
  if (Trim(LblForumMsg.Text) <> '')
  {
    formK = 512;
  }
  PnlKartForm.Height = formK;

  bodyH = formK + 12 + kartL + PnlBody.Margins.Top + PnlBody.Margins.Bottom + C_SAFE_BOTTOM + 16;
  bodyH = IMax(bodyH, FormTA.clHeight - 58 + C_SAFE_BOTTOM);
  bodyH = IMax(bodyH, 640);
  PnlBody.Height = bodyH;

  PnlSolToolbar.Height = 54;
  if (innerW < 340)
  {
    PnlToolPrefix.Width = 72;
  }
  else
  {
    PnlToolPrefix.Width = 104;
  }

  if (innerW < 340)
  {
    EdtTalepAra.clProSettings.FontSize = 11;
    EdtTalepAra.SetclProSettings(EdtTalepAra.clProSettings);
    EdtTalepAra.TextPrompt = 'Numara, baslik veya konum';
    BtnTalepAra.clProSettings.FontSize = 11;
    BtnTalepAra.SetclProSettings(BtnTalepAra.clProSettings);
  }
  else
  {
    EdtTalepAra.clProSettings.FontSize = 13;
    EdtTalepAra.SetclProSettings(EdtTalepAra.clProSettings);
    EdtTalepAra.TextPrompt = 'Numara, baslik veya konum';
    BtnTalepAra.clProSettings.FontSize = 12;
    BtnTalepAra.SetclProSettings(BtnTalepAra.clProSettings);
  }

  if (LvDesigner <> nil)
  {
    LvDesigner.Width = IMax(200, innerW - 64);
    LvDesigner.SetclProSettings(LvDesigner.clProSettings);
  }
  TaleplerimListeDesignerRenkYenile;
}


// =========================== [EVENT HANDLERS] ================================

void ListeyiYenile;
var
  uid  : String;
  json : String;
{
  uid = SessionGet('UserId');
  if (uid == '')
  {
    ShowMessage('Oturum yok, lutfen tekrar giris yapin');
    Clomosy.RunUnit('uLogin');
    FormTA.clHide;
  }
  else
  {
    try
      json = RtdbGet('tickets', 'orderBy="talepAcanId"&equalTo="' + uid + '"');
      SessionSet('LastReqResp', json);
      LastTalepimJson = json;
      try
        TaleplerimListesiYukle(json, Trim(EdtTalepAra.Text));
      except
        LastTalepimJson = '';
        LbTalepler.ClearList;
        TaleplerimListeGorunum(False);
        LblTalepCount.Text = '0 talep';
        LblForumMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
        LblForumMsg.SetclProSettings(LblForumMsg.clProSettings);
        LblForumMsg.Text = 'Liste hatasi: ' + LastExceptionMessage;
      }
    except
      LastTalepimJson = '';
      LbTalepler.ClearList;
      TaleplerimListeGorunum(False);
      LblTalepCount.Text = '0 talep';
      LblForumMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
      LblForumMsg.SetclProSettings(LblForumMsg.clProSettings);
      LblForumMsg.Text = 'Listeleme (RTDB): ' + LastExceptionMessage;
    }
  }
  LblForumMsgBoslukAyarla;
  YerlesimLayoutIste;
}


void ListeyiYenileBaslat;
{
  LblForumMsg.Text = '';
  LblForumMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
  LblForumMsg.SetclProSettings(LblForumMsg.clProSettings);
  LblForumMsgBoslukAyarla;
  ListeyiYenile;
}


void YerlesimLayoutTick;
{
  UygulaResponsiveTalepAcma;
  if (IlkTalepListeKaldi <> 0)
  {
    IlkTalepListeKaldi = 0;
    ListeyiYenile;
  }
  TmrYerlesim.Enabled = False;
}


void OlusturClick;
var
  uid      : String;
  baslik   : String;
  aciklama : String;
  konum    : String;
  oncelik  : String;
  ticketNo : String;
  now_     : String;
  sla      : String;
  body     : String;
  resp     : String;
  newKey   : String;
  ev       : String;
{
  LblForumMsg.Text = '';
  LblForumMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
  LblForumMsg.SetclProSettings(LblForumMsg.clProSettings);
  LblForumMsgBoslukAyarla;

  baslik   = Trim(EdtTalepBaslik.Text);
  aciklama = Trim(EdtAciklama.Text);
  konum    = Trim(EdtKonum.Text);
  oncelik  = CmbOncelik.GetValueIndex(CmbOncelik.ItemIndex);

  if ((baslik == '') || (konum == '') || (oncelik == ''))
  {
    LblForumMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
    LblForumMsg.SetclProSettings(LblForumMsg.clProSettings);
    LblForumMsg.Text = 'Baslik, konum ve oncelik zorunlu';
  }
  else
  {
    uid      = SessionGet('UserId');
    ticketNo = TicketNoUret;
    now_     = NowIso;
    sla      = SlaDeadline(oncelik);

    body = '{' +
      '"ticketNo":"'         + JsonEsc(ticketNo) + '",' +
      '"baslik":"'           + JsonEsc(baslik)   + '",' +
      '"aciklama":"'         + JsonEsc(aciklama) + '",' +
      '"konum":"'            + JsonEsc(konum)    + '",' +
      '"oncelik":"'          + oncelik           + '",' +
      '"durum":"Acik",' +
      '"talepAcanId":"'      + uid               + '",' +
      '"atananPersonelId":"",' +
      '"createdAt":"'        + now_              + '",' +
      '"updatedAt":"'        + now_              + '",' +
      '"slaDeadline":"'      + sla               + '"' +
    '}';

    try
      resp = RtdbPost('tickets', body);
      newKey = RtdbPostKeyOku(resp);

      if (newKey == '')
      {
        LblForumMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
        LblForumMsg.SetclProSettings(LblForumMsg.clProSettings);
        LblForumMsg.Text = 'Kayit basarisiz: ' + resp;
      }
      else
      {
        ev = '{' +
          '"fromStatus":"",' +
          '"toStatus":"Acik",' +
          '"changedBy":"' + uid + '",' +
          '"changedAt":"' + now_ + '",' +
          '"note":"Talep olusturuldu"' +
        '}';
        RtdbPost('tickets/' + newKey + '/events', ev);

        LblForumMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_SUCCESS);
        LblForumMsg.SetclProSettings(LblForumMsg.clProSettings);
        LblForumMsg.Text = 'Talep olusturuldu: ' + ticketNo;
        EdtTalepBaslik.Text = '';
        EdtAciklama.Text    = '';
        EdtKonum.Text       = '';
        ListeyiYenile;
      }
    except
      LblForumMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
      LblForumMsg.SetclProSettings(LblForumMsg.clProSettings);
      LblForumMsg.Text = 'Hata: ' + LastExceptionMessage;
    }
  }
  LblForumMsgBoslukAyarla;
  YerlesimLayoutIste;
}


void YenileClick;
{
  ListeyiYenileBaslat;
}


void CikisClick;
{
  SessionClear;
  Clomosy.RunUnit('uLogin');
  FormTA.clHide;
}


