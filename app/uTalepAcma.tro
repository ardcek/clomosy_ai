    LblEmptyTitle.Margins.Left  = 12;
    LblEmptyTitle.Margins.Right = 12;
    LblEmptyTitle.clProSettings.FontSize = 15;
    LblEmptyTitle.clProSettings.TextSettings.Font.Style = [fsBold];
    LblEmptyTitle.clProSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
    LblEmptyTitle.clProSettings.FontHorzAlign = palCenter;
    LblEmptyTitle.clProSettings.WordWrap = True;
    LblEmptyTitle.SetclProSettings(LblEmptyTitle.clProSettings);

    LblEmptySub = FormTA.AddNewProLabel(PnlEmptyCenter, 'LblEmptySub',
      'Yenile ile listeyi guncelleyin. Arama kutusu ile filtreleyebilirsiniz.');
    LblEmptySub.Align = alTop;
    LblEmptySub.Height = 56;
    LblEmptySub.Margins.Left   = 14;
    LblEmptySub.Margins.Right  = 14;
    LblEmptySub.Margins.Top    = 8;
    LblEmptySub.clProSettings.FontSize = 12;
    LblEmptySub.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LblEmptySub.clProSettings.FontHorzAlign = palCenter;
    LblEmptySub.clProSettings.WordWrap = True;
    LblEmptySub.SetclProSettings(LblEmptySub.clProSettings);

    Adim = '10: LbTalepler TclProListView';
    LbTalepler = FormTA.AddNewProListView(PnlListHost, 'LbTalepler');
    LbTalepler.Align = alClient;
    LbTalepler.Margins.Left   = 8;
    LbTalepler.Margins.Right  = 8;
    LbTalepler.Margins.Top    = 8;
    LbTalepler.Margins.Bottom = 8;
    LbTalepler.clProSettings.ViewType = lvWaterFall;
    LbTalepler.clProSettings.IsRound = True;
    LbTalepler.clProSettings.IsFill = True;
    LbTalepler.clProSettings.ColCount = 1;
    LbTalepler.clProSettings.ItemHeight = 128;
    LbTalepler.clProSettings.ItemSpace = 8;
    LbTalepler.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_INSET);
    LbTalepler.clProSettings.BorderColor = clAlphaColor.clHexToColor(C_BORDER);
    LbTalepler.clProSettings.BorderWidth = 1;
    LbTalepler.clProSettings.RoundWidth = 8;
    LbTalepler.clProSettings.RoundHeight = 8;
    LbTalepler.SetclProSettings(LbTalepler.clProSettings);

    LvDesigner = FormTA.AddNewProListViewDesignerPanel(LbTalepler, 'LvDesigner');
    LvDesigner.Align = alTop;
    LvDesigner.Height = 118;
    LvDesigner.Width = 352;
    LvDesigner.Margins.Left = 0;
    LvDesigner.Margins.Right = 0;
    LvDesigner.clProSettings.IsRound = True;
    LvDesigner.clProSettings.IsFill = True;
    LvDesigner.clProSettings.ItemHeight = 128;
    LvDesigner.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
    LvDesigner.clProSettings.BorderColor = clAlphaColor.clHexToColor(C_BORDER);
    LvDesigner.clProSettings.BorderWidth = 1;
    LvDesigner.clProSettings.RoundWidth = 10;
    LvDesigner.clProSettings.RoundHeight = 10;
    LvDesigner.SetclProSettings(LvDesigner.clProSettings);
    LbTalepler.SetDesignerPanel(LvDesigner);

    LvLMain = FormTA.AddNewProLabel(LvDesigner, 'MAIN_TEXT', '{MAIN_TEXT}');
    LvLMain.Align = alMostTop;
    LvLMain.Height = 38;
    LvLMain.Margins.Top = 8;
    LvLMain.Margins.Left = 12;
    LvLMain.Margins.Right = 12;
    LvLMain.clProSettings.FontSize = 14;
    LvLMain.clProSettings.TextSettings.Font.Style = [fsBold];
    LvLMain.clProSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
    LvLMain.clProSettings.TextSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
    LvLMain.clProSettings.IsTransparent = False;
    LvLMain.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
    LvLMain.clProSettings.FontVertAlign = palCenter;
    LvLMain.clProSettings.FontHorzAlign = palLeading;
    LvLMain.clProSettings.WordWrap = True;
    LvLMain.SetclProSettings(LvLMain.clProSettings);
    LvDesigner.AddPanelObject(LvLMain, clCaption);

    LvLSub = FormTA.AddNewProLabel(LvDesigner, 'SUB_TEXT', '{SUB_TEXT}');
    LvLSub.Align = alMostTop;
    LvLSub.Height = 28;
    LvLSub.Margins.Top = 4;
    LvLSub.Margins.Left = 12;
    LvLSub.Margins.Right = 12;
    LvLSub.clProSettings.FontSize = 12;
    LvLSub.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LvLSub.clProSettings.TextSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LvLSub.clProSettings.IsTransparent = False;
    LvLSub.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
    LvLSub.clProSettings.WordWrap = True;
    LvLSub.SetclProSettings(LvLSub.clProSettings);
    LvDesigner.AddPanelObject(LvLSub, clText);

    LvLFoot = FormTA.AddNewProLabel(LvDesigner, 'FOOTER_TEXT', '{FOOTER_TEXT}');
    LvLFoot.Align = alMostTop;
    LvLFoot.Height = 22;
    LvLFoot.Margins.Top = 4;
    LvLFoot.Margins.Left = 12;
    LvLFoot.Margins.Right = 12;
    LvLFoot.clProSettings.FontSize = 11;
    LvLFoot.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LvLFoot.clProSettings.TextSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LvLFoot.clProSettings.IsTransparent = False;
    LvLFoot.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
    LvLFoot.SetclProSettings(LvLFoot.clProSettings);
    LvDesigner.AddPanelObject(LvLFoot, clText1);

    LbTalepler.Visible = False;
    PnlEmptyState.Visible = True;

    Adim = '12: UygulaResponsiveTalepAcma ilk';
    UygulaResponsiveTalepAcma;

    Adim = '13: TmrYerlesim';
    TmrYerlesim = FormTA.AddNewTimer(FormTA, 'TmrYerlesim', 200);
    FormTA.AddNewEvent(TmrYerlesim, tbeOnTimer, 'YerlesimLayoutTick');
    TmrYerlesim.Enabled = True;

    Adim = '14: FormTA.Run';
    FormTA.Run;

  except
    ShowMessage('Talep ekrani hatasi (adim ' + Adim + '): ' +
                LastExceptionClassName + ' / ' + LastExceptionMessage);
  }
}
