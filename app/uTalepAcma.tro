  C_PRIMARY_BG  = '#EFF6FF';
  C_DANGER      = '#EF4444';
  C_DANGER_BG   = '#FEF2F2';
  C_SUCCESS     = '#10B981';
  C_TEXT        = '#0F172A';
  C_MUTED       = '#64748B';
  C_ON_SOLID    = '#FFFFFF';
  C_HEADER_BAR  = '#EFF6FF';
  C_MUTED_BG    = '#EEF2FF';
  C_BODY_END    = '#E8EDF5';
  C_BREAK_NARROW = 760;
  C_SAFE_BOTTOM  = 40;


