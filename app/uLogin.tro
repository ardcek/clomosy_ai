    LblHataMsg.SetclProSettings(LblHataMsg.clProSettings);
    LblHataMsgBoslukAyarla;

    Adim = '13: UygulaResponsiveLogin ilk';
    UygulaResponsiveLogin;

    Adim = '14: TmrYerlesim';
    TmrYerlesim = FormLogin.AddNewTimer(FormLogin, 'TmrYerlesim', 200);
    FormLogin.AddNewEvent(TmrYerlesim, tbeOnTimer, 'YerlesimLayoutTick');
    TmrYerlesim.Enabled = True;

    Adim = '15: FormLogin.Run';
    FormLogin.Run;

  except
    ShowMessage('Login form hatasi (adim ' + Adim + '): ' +
                LastExceptionClassName + ' / ' + LastExceptionMessage);
  }
}
