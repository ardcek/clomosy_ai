    LblAyrac = FormY.AddNewProLabel(PnlSag, 'LblAyrac', '');
    LblAyrac.Align = alTop;
    LblAyrac.Height = 1;
    LblAyrac.Margins.Left  = 16;
    LblAyrac.Margins.Right = 16;
    LblAyrac.Margins.Bottom = 8;
    LblAyrac.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_BORDER);
    LblAyrac.SetclProSettings(LblAyrac.clProSettings);

    Adim = '23: LblPersLbl';
    LblPersLbl = FormY.AddNewProLabel(PnlSag, 'LblPersLbl', 'Saha personeli');
    LblPersLbl.Align = alTop;
    LblPersLbl.Height = 20;
    LblPersLbl.Margins.Left  = 16;
    LblPersLbl.Margins.Right = 16;
    LblPersLbl.Margins.Bottom = 6;
    LblPersLbl.clProSettings.FontSize = 12;
    LblPersLbl.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LblPersLbl.SetclProSettings(LblPersLbl.clProSettings);

    Adim = '24: PnlPersRow';
    PnlPersRow = FormY.AddNewProPanel(PnlSag, 'PnlPersRow');
    PnlPersRow.Align = alTop;
    PnlPersRow.Height = 52;
    PnlPersRow.Margins.Left   = 16;
    PnlPersRow.Margins.Right  = 16;
    PnlPersRow.Margins.Bottom = 12;
    PnlPersRow.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_SURFACE);
    PnlPersRow.clProSettings.BorderColor = clAlphaColor.clHexToColor(C_BORDER);
    PnlPersRow.clProSettings.BorderWidth = 1;
    PnlPersRow.SetclProSettings(PnlPersRow.clProSettings);

    Adim = '25: BtnPersYenile';
    BtnPersYenile = FormY.AddNewProButton(PnlPersRow, 'BtnPersYenile', 'Yenile');
    BtnPersYenile.Align = alRight;
    BtnPersYenile.Width = 84;
    BtnPersYenile.Height = 40;
    BtnPersYenile.Margins.Top = 6;
    BtnPersYenile.Margins.Bottom = 6;
    BtnPersYenile.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_PRIMARY_BG);
    BtnPersYenile.clProSettings.FontColor = clAlphaColor.clHexToColor(C_PRIMARY);
    BtnPersYenile.clProSettings.BorderColor = clAlphaColor.clHexToColor(C_PRIMARY);
    BtnPersYenile.clProSettings.BorderWidth = 1;
    BtnPersYenile.clProSettings.IsRound = True;
    BtnPersYenile.clProSettings.RoundHeight = 8;
    BtnPersYenile.clProSettings.RoundWidth = 8;
    BtnPersYenile.SetclProSettings(BtnPersYenile.clProSettings);
    FormY.AddNewEvent(BtnPersYenile, tbeOnClick, 'PersonelleriYenile');

    Adim = '26: CmbPersonel';
    CmbPersonel = FormY.AddNewComboBox(PnlPersRow, 'CmbPersonel');
    CmbPersonel.Align = alClient;
    CmbPersonel.Margins.Left   = 0;
    CmbPersonel.Margins.Right  = 8;
    CmbPersonel.Margins.Top    = 6;
    CmbPersonel.Margins.Bottom = 6;

    Adim = '27: LblNotLbl';
    LblNotLbl = FormY.AddNewProLabel(PnlSag, 'LblNotLbl', 'Atama notu');
    LblNotLbl.Align = alTop;
    LblNotLbl.Height = 20;
    LblNotLbl.Margins.Left  = 16;
    LblNotLbl.Margins.Right = 16;
    LblNotLbl.Margins.Bottom = 6;
    LblNotLbl.clProSettings.FontSize = 12;
    LblNotLbl.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LblNotLbl.SetclProSettings(LblNotLbl.clProSettings);

    Adim = '28: EdtNot';
    EdtNot = FormY.AddNewProEdit(PnlSag, 'EdtNot', '');
    EdtNot.Align  = alTop;
    EdtNot.Height = 44;
    EdtNot.Margins.Left   = 16;
    EdtNot.Margins.Right  = 16;
    EdtNot.Margins.Bottom = 12;
    EdtNot.TextPrompt = 'Opsiyonel - kisa not';
    EdtNot.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
    EdtNot.clProSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
    EdtNot.clProSettings.BorderColor = clAlphaColor.clHexToColor(C_BORDER);
    EdtNot.clProSettings.BorderWidth = 1;
    EdtNot.clProSettings.IsRound = True;
    EdtNot.clProSettings.RoundHeight = 8;
    EdtNot.clProSettings.RoundWidth = 8;
    EdtNot.SetclProSettings(EdtNot.clProSettings);

    Adim = '29: BtnAta';
    BtnAta = FormY.AddNewProButton(PnlSag, 'BtnAta', 'Atama Yap');
    BtnAta.Align  = alTop;
    BtnAta.Height = 52;
    BtnAta.Margins.Left   = 16;
    BtnAta.Margins.Right  = 16;
    BtnAta.Margins.Bottom = 10;
    BtnAta.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_PRIMARY);
    BtnAta.clProSettings.BorderColor = clAlphaColor.clHexToColor(C_PRIMARY);
    BtnAta.clProSettings.BorderWidth = 0;
    BtnAta.clProSettings.FontColor = clAlphaColor.clHexToColor(C_ON_SOLID);
    BtnAta.clProSettings.FontSize = 15;
    BtnAta.clProSettings.TextSettings.Font.Style = [fsBold];
    BtnAta.clProSettings.IsRound = True;
    BtnAta.clProSettings.RoundHeight = 12;
    BtnAta.clProSettings.RoundWidth = 12;
    BtnAta.SetclProSettings(BtnAta.clProSettings);
    FormY.AddNewEvent(BtnAta, tbeOnClick, 'AtaClick');

    Adim = '30: LblMsg';
    LblMsg = FormY.AddNewProLabel(PnlSag, 'LblMsg', '');
    LblMsg.Align = alTop;
    LblMsg.Height = 42;
    LblMsg.Margins.Left   = 16;
    LblMsg.Margins.Right  = 16;
    LblMsg.Margins.Top    = 6;
    LblMsg.Margins.Bottom = 14;
    LblMsg.clProSettings.FontHorzAlign = palCenter;
    LblMsg.clProSettings.FontSize = 11;
    LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LblMsg.clProSettings.WordWrap = True;
    LblMsg.clProSettings.FontVertAlign = palCenter;
    LblMsg.SetclProSettings(LblMsg.clProSettings);

    Adim = '30b: UygulaResponsiveYerlesim';
    UygulaResponsiveYerlesim;

    Adim = '31: OzetBos';
    OzetBos;
    Adim = '31b: LbTalepler.ClearList';
    LbTalepler.ClearList;
    TalepListeGorunum(False);

    Adim = '31c: TmrYerlesim';
    TmrYerlesim = FormY.AddNewTimer(FormY, 'TmrYerlesim', 200);
    FormY.AddNewEvent(TmrYerlesim, tbeOnTimer, 'YerlesimLayoutTick');
    TmrYerlesim.Enabled = True;

    Adim = '32: FormY.Run';
    FormY.Run;

  except
    ShowMessage('Atama ekrani hatasi (adim ' + Adim + '): ' +
                LastExceptionClassName + ' / ' + LastExceptionMessage);
  }
}
