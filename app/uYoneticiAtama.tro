// ============================ [SNIPPET: uRtdb] ===============================

// ============================ [SNIPPET: Session] =============================
// Clomosy.GlobalVariableString TEK scalar slot. Coklu key icin pipe ayrim:
//   |Token=...|UserId=...|AdSoyad=...|

function SessionGet(key : String) : String;
var
  s, marker, rest : String;
{
  s = Clomosy.GlobalVariableString;
  marker = '|' + key + '=';
  if (Pos(marker, s) > 0)
  {
    rest = clGetStringAfter(s, marker);
    Result = clGetStringTo(rest, '|');
  }
  else
  {
    Result = '';
  }
}

void SessionSet(key : String; value : String);
var
  s, marker, before, rest, after : String;
{
  s = Clomosy.GlobalVariableString;
  if (s == '')
  {
    s = '|';
  }
  if (Copy(s, 1, 1) <> '|')
  {
    s = '|' + s;
  }
  if (Copy(s, Length(s), 1) <> '|')
  {
    s = s + '|';
  }

  marker = '|' + key + '=';
  if (Pos(marker, s) > 0)
  {
    before = clGetStringTo(s, marker);
    rest   = clGetStringAfter(s, marker);
    after  = clGetStringAfter(rest, '|');
    s = before + marker + value + '|' + after;
  }
  else
  {
    s = s + key + '=' + value + '|';
  }

  Clomosy.GlobalVariableString = s;
}

void SessionClear;
{
  Clomosy.GlobalVariableString = '';
}


function DbUrl : String;
var u : String;
{
  u = SessionGet('DbUrl');
  if (u == '')
  {
    Result = 'https://akilli-ariza-saha-default-rtdb.europe-west1.firebasedatabase.app';
  }
  else
  {
    Result = u;
  }
}

function Token : String;
{
  Result = SessionGet('Token');
}

function AuthQuery : String;
{
  Result = 'auth=' + Token;
}

function RtdbUrl(Path : String; ExtraQuery : String) : String;
var q : String;
{
  q = AuthQuery;
  if (ExtraQuery <> '')
  {
    q = q + '&' + ExtraQuery;
  }
  Result = DbUrl + '/' + Path + '.json?' + q;
}

function JsonEsc(S : String) : String;
var R : String;
{
  R = clGetStringReplace(S, '\', '\\');
  R = clGetStringReplace(R, '"', '\"');
  R = clGetStringReplace(R, Chr(13), '');
  R = clGetStringReplace(R, Chr(10), ' ');
  Result = R;
}

function RtdbGet(Path : String; Query : String) : String;
var
  R   : TclRest;
  url : String;
{
  url = RtdbUrl(Path, Query);
  SessionSet('LastReqUrl', url);
  R = TclRest.Create;
  try
    R.BaseURL = url;
    R.Method  = rmGET;
    R.Accept  = 'application/json';
    R.Execute;
    Result = R.Response;
    SessionSet('LastReqResp', Result);
  finally
    R.Free;
  }
}

function RtdbPost(Path : String; BodyJson : String) : String;
var
  R   : TclRest;
  url : String;
{
  url = RtdbUrl(Path, '');
  SessionSet('LastReqUrl', url);
  R = TclRest.Create;
  try
    R.BaseURL     = url;
    R.Method      = rmPOST;
    R.Accept      = 'application/json';
    R.ContentType = 'application/json';
    R.Body        = BodyJson;
    R.Execute;
    Result = R.Response;
    SessionSet('LastReqResp', Result);
  finally
    R.Free;
  }
}

function RtdbPatch(Path : String; BodyJson : String) : String;
var
  R   : TclRest;
  url : String;
{
  url = RtdbUrl(Path, '');
  SessionSet('LastReqUrl', url);
  R = TclRest.Create;
  try
    R.BaseURL     = url;
    R.Method      = rmPATCH;
    R.Accept      = 'application/json';
    R.ContentType = 'application/json';
    R.Body        = BodyJson;
    R.Execute;
    Result = R.Response;
    SessionSet('LastReqResp', Result);
  finally
    R.Free;
  }
}

function JsonStrAlan(Json : String; Alan : String) : String;
var
  marker : String;
  s      : String;
{
  marker = '"' + Alan + '"';
  if (Pos(marker, Json) == 0)
  {
    Result = '';
  }
  else
  {
    s = clGetStringAfter(Json, marker);
    s = clGetStringAfter(s, ':');
    s = clGetStringAfter(s, '"');
    Result = clGetStringTo(s, '"');
  }
}

function NowIso : String;
{
  Result = FormatDateTime('yyyy-mm-dd"T"hh:nn:ss"Z"', Now);
}


// =========================== [LISTE PARSE HELPERS] ===========================

void OzetBos;
{
  LblSeciliId.Text   = 'Listeden bir talep secin';
  LblSeciliBaslik.Text = '';
  LblSeciliMeta.Text = '';
  LblSeciliId.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
  LblSeciliId.clProSettings.TextSettings.Font.Style = [fsItalic];
  LblSeciliId.SetclProSettings(LblSeciliId.clProSettings);
  PnlSecili.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_INSET);
  PnlSecili.clProSettings.BorderColor = clAlphaColor.clHexToColor(C_BORDER);
  PnlSecili.clProSettings.BorderWidth = 1;
  PnlSecili.SetclProSettings(PnlSecili.clProSettings);
}

void OzetGoster(ticketNo, baslik, oncelik, konum : String);
{
  LblSeciliId.Text     = ticketNo;
  LblSeciliBaslik.Text = baslik;
  if ((oncelik <> '') && (konum <> ''))
  {
    LblSeciliMeta.Text = oncelik + '  |  ' + konum;
  }
  else if (konum <> '')
  {
    LblSeciliMeta.Text = konum;
  }
  else if (oncelik <> '')
  {
    LblSeciliMeta.Text = oncelik;
  }
  else
  {
    LblSeciliMeta.Text = '';
  }
  LblSeciliId.clProSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
  LblSeciliId.clProSettings.TextSettings.Font.Style = [fsBold];
  LblSeciliId.SetclProSettings(LblSeciliId.clProSettings);
  PnlSecili.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_PRIMARY_BG);
  PnlSecili.clProSettings.BorderColor = clAlphaColor.clHexToColor(C_PRIMARY);
  PnlSecili.clProSettings.BorderWidth = 2;
  PnlSecili.SetclProSettings(PnlSecili.clProSettings);
}

void TalepListeGorunum(listeDolu : Boolean);
{
  if (listeDolu)
  {
    LbTalepler.Visible = True;
    PnlEmptyState.Visible = False;
    LbTalepler.BringToFront;
  }
  else
  {
    LbTalepler.Visible = False;
    PnlEmptyState.Visible = True;
  }
}


void TalepListeDesignerRenkYenile;
{
  if (LvDesigner <> nil)
  {
    LvDesigner.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
    LvDesigner.SetclProSettings(LvDesigner.clProSettings);
  }
  if (LvLMain <> nil)
  {
    LvLMain.clProSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
    LvLMain.clProSettings.TextSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
    LvLMain.clProSettings.IsTransparent = False;
    LvLMain.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
    LvLMain.SetclProSettings(LvLMain.clProSettings);
  }
  if (LvLSub <> nil)
  {
    LvLSub.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LvLSub.clProSettings.TextSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LvLSub.clProSettings.IsTransparent = False;
    LvLSub.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
    LvLSub.SetclProSettings(LvLSub.clProSettings);
  }
  if (LvLFoot <> nil)
  {
    LvLFoot.clProSettings.FontColor = clAlphaColor.clHexToColor(C_PRIMARY);
    LvLFoot.clProSettings.TextSettings.FontColor = clAlphaColor.clHexToColor(C_PRIMARY);
    LvLFoot.clProSettings.IsTransparent = False;
    LvLFoot.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
    LvLFoot.SetclProSettings(LvLFoot.clProSettings);
  }
}

void TalepListesiYukle(json : String; filtre : String; resetOzet : Integer);
var
  rem, key, blok : String;
  baslangic, adet : Integer;
  ticketNo, baslik, oncelik : String;
  konum, createdAt, footerSaat : String;
  arr : String;
  hay : String;
  ned : String;
  ilk : Boolean;
  gec : Boolean;
  depth, idx : Integer;
  ch : String;
  inStr, esc : Boolean;
{
  arr = '[';
  ilk = True;
  adet = 0;
  ned = Trim(filtre);

  if (resetOzet <> 0)
  {
    OzetBos;
    LblTalepCount.Text = '0 talep';
    LblSecili.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LblSecili.clProSettings.TextSettings.Font.Style = [fsItalic];
    LblSecili.SetclProSettings(LblSecili.clProSettings);
    LblSecili.Text = 'Henuz acik talep yok';
  }

  if ((json == '') || (json == 'null') || (json == '{}'))
  {
    LbTalepler.ClearList;
    TalepListeGorunum(False);
    if (resetOzet <> 0)
    {
      LblTalepCount.Text = '0 talep';
    }
    Exit;
  }

  rem = json;
  while (Pos('":{', rem) > 0)
  {
    baslangic = Pos('"', rem);
    if (baslangic == 0) { break; }
    rem = Copy(rem, baslangic + 1, Length(rem));

    key = clGetStringTo(rem, '":{');
    rem = clGetStringAfter(rem, '":{');

    depth = 1;
    idx   = 1;
    inStr = False;
    esc   = False;
    while ((idx <= Length(rem)) && (depth > 0))
    {
      ch = Copy(rem, idx, 1);
      if (esc == True)
      {
        esc = False;
      }
      else if (ch == Chr(92))
      {
        esc = True;
      }
      else if (ch == '"')
      {
        inStr = (inStr == False);
      }
      else if (inStr == False)
      {
        if      (ch == '{') { depth = depth + 1; }
        else if (ch == '}') { depth = depth - 1; }
      }
      idx = idx + 1;
    }
    blok = Copy(rem, 1, idx - 2);
    rem  = Copy(rem, idx, Length(rem));

    ticketNo  = JsonStrAlan('{' + blok + '}', 'ticketNo');
    baslik    = JsonStrAlan('{' + blok + '}', 'baslik');
    oncelik   = JsonStrAlan('{' + blok + '}', 'oncelik');
    konum     = JsonStrAlan('{' + blok + '}', 'konum');
    createdAt = JsonStrAlan('{' + blok + '}', 'createdAt');

    gec = True;
    if (ned <> '')
    {
      hay = AnsiLowerCase(ticketNo + ' ' + baslik + ' ' + konum + ' ' + oncelik);
      if (Pos(AnsiLowerCase(ned), hay) == 0)
      {
        gec = False;
      }
    }
    if (gec == True)
    {

    if (Length(createdAt) >= 16)
    {
      footerSaat = Copy(createdAt, 12, 5);
    }
    else if (createdAt <> '')
    {
      footerSaat = createdAt;
    }
    else
    {
      footerSaat = '--:--';
    }

    if (ilk == False) { arr = arr + ','; }
    // ProListView: MAIN_TEXT ilk alan (clCaption baglantisinda bazi surumler ilk kolonu kullanir); RECORD_GUID son.
    arr = arr + '{"MAIN_TEXT":"' + JsonEsc(ticketNo + ' - ' + baslik) + '",' +
                '"SUB_TEXT":"' + JsonEsc(konum + '  |  ' + oncelik) + '",' +
                '"FOOTER_TEXT":"' + JsonEsc('Acildi: ' + footerSaat) + '",' +
                '"RECORD_GUID":"' + key + '"}';
    ilk = False;
    adet = adet + 1;
    }
  }

  if (ilk == False)
  {
    arr = arr + ']';
    LbTalepler.clLoadProListViewDataFromDataset(Clomosy.ClDataSetFromJSON(arr));
    TalepListeGorunum(True);
    TalepListeDesignerRenkYenile;
    LbTalepler.SetclProSettings(LbTalepler.clProSettings);
    LblTalepCount.Text = IntToStr(adet) + ' talep';
    if (resetOzet <> 0)
    {
      LblSecili.Text = 'Bir talep secin';
      LblSecili.clProSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
      LblSecili.clProSettings.TextSettings.Font.Style = [];
      LblSecili.SetclProSettings(LblSecili.clProSettings);
    }
  }
  else
  {
    LbTalepler.ClearList;
    TalepListeGorunum(False);
    LblTalepCount.Text = '0 talep';
    if (resetOzet <> 0)
    {
      LblSecili.Text = 'Henuz acik talep yok';
      LblSecili.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
      LblSecili.clProSettings.TextSettings.Font.Style = [fsItalic];
      LblSecili.SetclProSettings(LblSecili.clProSettings);
    }
  }
}

void PersonelListesiYukle(json : String);
var
  rem, key, blok : String;
  baslangic : Integer;
  adSoyad, email : String;
  depth, idx : Integer;
  ch : String;
  inStr, esc : Boolean;
{
  CmbPersonel.Clear;
  // Bos listede dar ekranda kirpilan metin olmasin; placeholder secili tutulur (value '').
  CmbPersonel.AddItem('Personel secin', '');

  if ((json == '') || (json == 'null') || (json == '{}'))
  {
    CmbPersonel.ItemIndex = 0;
    Exit;
  }

  rem = json;
  while (Pos('":{', rem) > 0)
  {
    baslangic = Pos('"', rem);
    if (baslangic == 0) { break; }
    rem = Copy(rem, baslangic + 1, Length(rem));

    key = clGetStringTo(rem, '":{');
    rem = clGetStringAfter(rem, '":{');

    depth = 1;
    idx   = 1;
    inStr = False;
    esc   = False;
    while ((idx <= Length(rem)) && (depth > 0))
    {
      ch = Copy(rem, idx, 1);
      if (esc == True)
      {
        esc = False;
      }
      else if (ch == Chr(92))
      {
        esc = True;
      }
      else if (ch == '"')
      {
        inStr = (inStr == False);
      }
      else if (inStr == False)
      {
        if      (ch == '{') { depth = depth + 1; }
        else if (ch == '}') { depth = depth - 1; }
      }
      idx = idx + 1;
    }
    blok = Copy(rem, 1, idx - 2);
    rem  = Copy(rem, idx, Length(rem));

    adSoyad = JsonStrAlan('{' + blok + '}', 'adSoyad');
    email   = JsonStrAlan('{' + blok + '}', 'email');

    CmbPersonel.AddItem(adSoyad + ' (' + email + ')', key);
  }

  CmbPersonel.ItemIndex = 0;
}


// ===================== [PERSONEL AKTIF GOREV SAYISI] =========================
// Bir uid icin Atandi/Yolda/Islemde durumundaki tickets sayisini hesaplar.
// RTDB GET tickets?orderBy="atananPersonelId"&equalTo="<uid>"
// donen map icinde durum'a gore filtre.

function PersonelAktifSayi(PersUid : String) : Integer;
var
  json, rem, blok, durum : String;
  baslangic, sayim : Integer;
  depth, idx : Integer;
  ch : String;
  inStr, esc : Boolean;
{
  sayim = 0;
  json  = RtdbGet('tickets', 'orderBy="atananPersonelId"&equalTo="' + PersUid + '"');

  if ((json == '') || (json == 'null') || (json == '{}'))
  {
    Result = 0;
  }
  else
  {
    rem = json;
    while (Pos('":{', rem) > 0)
    {
      baslangic = Pos('"', rem);
      if (baslangic == 0) { break; }
      rem = Copy(rem, baslangic + 1, Length(rem));

      rem = clGetStringAfter(rem, '":{');

      depth = 1;
      idx   = 1;
      inStr = False;
      esc   = False;
      while ((idx <= Length(rem)) && (depth > 0))
      {
        ch = Copy(rem, idx, 1);
        if (esc == True)
        {
          esc = False;
        }
        else if (ch == Chr(92))
        {
          esc = True;
        }
        else if (ch == '"')
        {
          inStr = (inStr == False);
        }
        else if (inStr == False)
        {
          if      (ch == '{') { depth = depth + 1; }
          else if (ch == '}') { depth = depth - 1; }
        }
        idx = idx + 1;
      }
      blok = Copy(rem, 1, idx - 2);
      rem  = Copy(rem, idx, Length(rem));

      durum = JsonStrAlan('{' + blok + '}', 'durum');
      if ((durum == 'Atandi') || (durum == 'Yolda') || (durum == 'Islemde'))
      {
        sayim = sayim + 1;
      }
    }
    Result = sayim;
  }
}


void TalepAramaDegisti;
{
  if (LastAcikTalepJson == '')
  {
    Exit;
  }
  TalepListesiYukle(LastAcikTalepJson, Trim(EdtTalepAra.Text), 0);
}

void YerlesimLayoutIste;
{
  if (TmrYerlesim <> nil)
  {
    TmrYerlesim.Enabled = True;
  }
}

// =========================== [EVENT HANDLERS] ================================

void TalepleriYenile;
var json : String;
{
  LblMsg.Text = '';
  LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
  LblMsg.SetclProSettings(LblMsg.clProSettings);
  try
    json = RtdbGet('tickets', 'orderBy="durum"&equalTo="Acik"');
    SessionSet('LastReqResp', json);
    try
      LastAcikTalepJson = json;
      TalepListesiYukle(json, Trim(EdtTalepAra.Text), 1);
    except
      LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
      LblMsg.SetclProSettings(LblMsg.clProSettings);
      LblMsg.Text = 'Liste hatasi: ' + LastExceptionMessage;
    }
  except
    LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
    LblMsg.SetclProSettings(LblMsg.clProSettings);
    LblMsg.Text = 'Talep listeleme (RTDB) hatasi: ' + LastExceptionMessage;
  }
  YerlesimLayoutIste;
}

void PersonelleriYenile;
var json : String;
{
  LblMsg.Text = '';
  LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
  LblMsg.SetclProSettings(LblMsg.clProSettings);
  try
    json = RtdbGet('users', 'orderBy="rol"&equalTo="SahaPersoneli"');
    SessionSet('LastReqResp', json);
    try
      PersonelListesiYukle(json);
    except
      LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
      LblMsg.SetclProSettings(LblMsg.clProSettings);
      LblMsg.Text = 'Personel hatasi: ' + LastExceptionMessage;
    }
  except
    LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
    LblMsg.SetclProSettings(LblMsg.clProSettings);
    LblMsg.Text = 'Personel listeleme (RTDB) hatasi: ' + LastExceptionMessage;
  }
  YerlesimLayoutIste;
}

void TalepSecildi;
var
  line1  : String;
  line2  : String;
  konum  : String;
  oncelik: String;
  p      : Integer;
  tNo, bl: String;
{
  line1 = LbTalepler.clSelectedItemData(clCaption);
  if (line1 == '')
  {
    OzetBos;
    LblSecili.Text = 'Bir talep secin';
    LblSecili.clProSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
    LblSecili.clProSettings.TextSettings.Font.Style = [];
    LblSecili.SetclProSettings(LblSecili.clProSettings);
  }
  else
  {
    line2 = LbTalepler.clSelectedItemData(clText);
    oncelik = '';
    konum   = '';
    if (line2 <> '')
    {
      p = Pos('  |  ', line2);
      if (p > 0)
      {
        konum = Copy(line2, 1, p - 1);
        oncelik = Copy(line2, p + 5, Length(line2) - p - 4);
      }
      else
      {
        konum = line2;
      }
    }
    p = Pos(' - ', line1);
    if (p > 0)
    {
      tNo = Copy(line1, 1, p - 1);
      if (p + 3 <= Length(line1))
      {
        bl = Copy(line1, p + 3, Length(line1) - p - 2);
      }
      else
      {
        bl = '';
      }
    }
    else
    {
      tNo = '';
      bl  = line1;
    }
    OzetGoster(tNo, bl, oncelik, konum);
    LblSecili.Text = 'Secildi: ' + line1;
    LblSecili.clProSettings.TextSettings.Font.Style = [];
    LblSecili.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LblSecili.SetclProSettings(LblSecili.clProSettings);
  }
}

void AtaClick;
var
  ticketId   : String;
  personelId : String;
  yoneticiId : String;
  not_       : String;
  now_       : String;
  body, ev   : String;
  resp1, resp2 : String;
  aktif      : Integer;
{
  LblMsg.Text = '';
  LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
  LblMsg.SetclProSettings(LblMsg.clProSettings);

  ticketId = LbTalepler.clSelectedItemData(clRecord_GUID);
  if (CmbPersonel.ItemIndex >= 0)
  {
    personelId = CmbPersonel.GetValueIndex(CmbPersonel.ItemIndex);
  }
  else
  {
    personelId = '';
  }

  if (ticketId == '')
  {
    LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
    LblMsg.SetclProSettings(LblMsg.clProSettings);
    LblMsg.Text = 'Lutfen bir talep secin';
  }
  else if (personelId == '')
  {
    LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
    LblMsg.SetclProSettings(LblMsg.clProSettings);
    LblMsg.Text = 'Lutfen bir personel secin';
  }
  else
  {
    yoneticiId = SessionGet('UserId');
    not_       = Trim(EdtNot.Text);
    now_       = NowIso;

    aktif = PersonelAktifSayi(personelId);
    if (aktif >= 5)
    {
      LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
      LblMsg.SetclProSettings(LblMsg.clProSettings);
      LblMsg.Text = 'Bu personelin 5 aktif gorevi var, atama yapilamaz';
    }
    else
    {
      body = '{' +
        '"durum":"Atandi",' +
        '"atananPersonelId":"' + personelId + '",' +
        '"updatedAt":"'        + now_       + '"' +
      '}';

      try
        Adim = 'PATCH tickets/' + ticketId;
        resp1 = RtdbPatch('tickets/' + ticketId, body);

        if (Pos('"error"', resp1) > 0)
        {
          LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
          LblMsg.SetclProSettings(LblMsg.clProSettings);
          LblMsg.Text = 'Atama yapilamadi (PATCH): ' + resp1;
        }
        else
        {
          ev = '{' +
            '"fromStatus":"Acik",' +
            '"toStatus":"Atandi",' +
            '"changedBy":"' + yoneticiId + '",' +
            '"changedAt":"' + now_ + '",' +
            '"note":"'      + JsonEsc(not_) + '"' +
          '}';
          Adim = 'POST tickets/' + ticketId + '/events';
          resp2 = RtdbPost('tickets/' + ticketId + '/events', ev);

          if (Pos('"error"', resp2) > 0)
          {
            LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
            LblMsg.SetclProSettings(LblMsg.clProSettings);
            LblMsg.Text = 'Atama yapilamadi (event): ' + resp2;
          }
          else
          {
            EdtNot.Text = '';
            TalepleriYenile;
            LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_SUCCESS);
            LblMsg.SetclProSettings(LblMsg.clProSettings);
            LblMsg.Text = 'Atama yapildi.';
          }
        }
      except
        LblMsg.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
        LblMsg.SetclProSettings(LblMsg.clProSettings);
        LblMsg.Text = 'Atama yapilamadi (' + Adim + '): ' + LastExceptionMessage;
      }
    }
  }
  YerlesimLayoutIste;
}

void CikisClick;
{
  SessionClear;
  Clomosy.RunUnit('uLogin');
  FormY.clHide;
}

function IMin(a, b : Integer) : Integer;
{
  if (a < b)
  {
    Result = a;
  }
  else
  {
    Result = b;
  }
}

function IMax(a, b : Integer) : Integer;
{
  if (a > b)
  {
    Result = a;
  }
  else
  {
    Result = b;
  }
}

// Bos mesaj satiri yer kaplamasin; genis modda LblMsg alClient kart altini sisirirdi.
void LblMsgBoslukAyarla;
var
  rw     : Integer;
  darCol : Boolean;
{
  rw = FormY.clWidth;
  darCol = (rw > 250) && (rw < C_BREAK_NARROW);
  if (Trim(LblMsg.Text) == '')
  {
    LblMsg.Visible = False;
    LblMsg.Height = 0;
    LblMsg.Margins.Top = 0;
    LblMsg.Margins.Bottom = 0;
    LblMsg.Align = alTop;
  }
  else
  {
    LblMsg.Visible = True;
    LblMsg.Align = alTop;
    LblMsg.clProSettings.WordWrap = True;
    LblMsg.clProSettings.FontVertAlign = palCenter;
    if (darCol)
    {
      LblMsg.Height = 44;
      LblMsg.Margins.Top = 6;
      LblMsg.Margins.Bottom = 12;
    }
    else
    {
      LblMsg.Height = 56;
      LblMsg.Margins.Top = 8;
      LblMsg.Margins.Bottom = 14;
    }
    LblMsg.SetclProSettings(LblMsg.clProSettings);
  }
}

// FormY.acilis genisligine gore iki sutun / alt alta yigilm (canli resize yok); TmrYerlesim ile gec guncellenir.
void UygulaResponsiveYerlesim;
var
  rawW     : Integer;
  bodyInnerW : Integer;
  solW     : Integer;
  solH     : Integer;
  sagH     : Integer;
  bodyH    : Integer;
  sideM    : Integer;
  innerW   : Integer;
  narrow   : Boolean;
  yenileW  : Integer;
  minSag   : Integer;
{
  rawW = FormY.clWidth;
  // 0..250: olus anı / sahte genislik => genis (iki sutun). Telefon portre cogu >= 320.
  narrow = (rawW > 250) && (rawW < C_BREAK_NARROW);
  if (narrow)
  {
    sideM = 8;
    PnlBody.Margins.Left   = sideM;
    PnlBody.Margins.Right  = sideM;
    PnlBody.Margins.Top    = 8;
    PnlBody.Margins.Bottom = 8;

    LblSecili.Visible = False;
    LblSecili.Height = 0;
    LblSecili.Margins.Bottom = 0;

    innerW = FormY.clWidth - PnlBody.Margins.Left - PnlBody.Margins.Right;
    innerW = IMax(innerW, 280);

    PnlSol.Align = alTop;
    PnlSol.Width = innerW;
    // Ust blok (eyebrow+title+count+toolbar) ~152px; bos durum karti ~230px+ — asagisi kirpilir / ust uste biner.
    solH = Round(FormY.clHeight * 0.44);
    solH = IMax(solH, 430);
    solH = IMin(solH, 580);
    PnlSol.Height = solH;
    PnlSol.Margins.Right = 0;
    PnlSol.Margins.Bottom = 0;

    PnlSag.Align = alTop;
    PnlSag.Width = innerW;
    // Bos mesajda saga kolon ve govde yuksekligi kirpilir.
    if (Trim(LblMsg.Text) == '')
    {
      sagH = Round(FormY.clHeight * 0.27);
      sagH = IMax(sagH, 426);
      sagH = IMin(sagH, 452);
    }
    else
    {
      sagH = Round(FormY.clHeight * 0.33);
      sagH = IMax(sagH, 502);
      sagH = IMin(sagH, 538);
    }
    PnlSag.Height = sagH;
    PnlSag.Margins.Top    = 12;
    PnlSag.Margins.Left   = 0;
    PnlSag.Margins.Right  = 0;
    PnlSag.Margins.Bottom = 8;

    bodyH = PnlSol.Height + PnlSag.Margins.Top + PnlSag.Height;
    bodyH = bodyH + PnlBody.Margins.Top + PnlBody.Margins.Bottom + C_SAFE_BOTTOM + 32;
    bodyH = IMax(bodyH, FormY.clHeight - 64 + C_SAFE_BOTTOM);
    bodyH = IMax(bodyH, 580);
    PnlBody.Height = bodyH;

    BtnCikis.Width = 72;
    LblKullanici.Margins.Right = BtnCikis.Width + 20;
    LblKullanici.clProSettings.FontSize = 12;
    LblKullanici.SetclProSettings(LblKullanici.clProSettings);

    PnlSolToolbar.Height = 54;
    PnlSolToolbar.Margins.Left   = 10;
    PnlSolToolbar.Margins.Right  = 10;
    PnlSolToolbar.Margins.Top    = 0;
    PnlSolToolbar.Margins.Bottom = 8;
    if (innerW < 340)
    {
      PnlToolPrefix.Width = 72;
      BtnYenile.Width = 56;
    }
    else
    {
      PnlToolPrefix.Width = 100;
      BtnYenile.Width = 88;
    }
    BtnYenile.clProSettings.FontSize = 11;
    BtnYenile.SetclProSettings(BtnYenile.clProSettings);

    PnlAraSutun.Width = 46;
    PnlAraSutun.Margins.Left = 0;
    PnlAraSutun.Margins.Top = 6;
    PnlAraSutun.Margins.Bottom = 6;
    PnlAraSutun.Margins.Right = 4;

    EdtTalepAra.Align = alClient;
    EdtTalepAra.Margins.Left = 8;
    EdtTalepAra.Margins.Right = 8;
    EdtTalepAra.Margins.Top = 8;
    EdtTalepAra.Margins.Bottom = 8;
    EdtTalepAra.Padding.Left = 8;
    EdtTalepAra.Padding.Right = 8;
    EdtTalepAra.Height = 38;
    EdtTalepAra.clProSettings.FontSize = 11;
    EdtTalepAra.SetclProSettings(EdtTalepAra.clProSettings);
    EdtTalepAra.TextPrompt = 'Numara, baslik veya konum';

    BtnTalepAra.clProSettings.FontSize = 11;
    BtnTalepAra.clProSettings.TextSettings.Font.Style = [fsBold];
    BtnTalepAra.SetclProSettings(BtnTalepAra.clProSettings);

    BtnPersYenile.Width = 60;
    BtnPersYenile.Height = 40;
    BtnPersYenile.Margins.Top = 6;
    BtnPersYenile.Margins.Bottom = 6;
    BtnPersYenile.clProSettings.FontSize = 11;
    BtnPersYenile.SetclProSettings(BtnPersYenile.clProSettings);
    CmbPersonel.Margins.Top = 6;
    CmbPersonel.Margins.Bottom = 6;
    CmbPersonel.Margins.Right = 4;

    PnlPersRow.Height = 54;
    EdtNot.TextPrompt = 'Not (opsiyonel)';

    LbTalepler.clProSettings.ItemHeight = 118;
    LbTalepler.clProSettings.ItemSpace = 6;
    LbTalepler.SetclProSettings(LbTalepler.clProSettings);
    LvDesigner.Height = 108;
    LvDesigner.clProSettings.ItemHeight = 118;
    LvDesigner.SetclProSettings(LvDesigner.clProSettings);

    LblBaslik.Width = IMin(220, IMax(150, innerW div 2));

    PnlTalepTitleRow.Height = 34;
    LblTalepCount.Width = 78;
    LblTalepCount.Height = 30;
    LblTalepCount.clProSettings.FontSize = 9;
    LblTalepCount.SetclProSettings(LblTalepCount.clProSettings);
    LblTalepTitle.clProSettings.FontSize = 15;
    LblTalepTitle.SetclProSettings(LblTalepTitle.clProSettings);

    PnlEmptyState.Margins.Left   = 10;
    PnlEmptyState.Margins.Right  = 10;
    PnlEmptyState.Margins.Top    = 8;
    PnlEmptyState.Margins.Bottom = 8;
    PnlEmptyCenter.Height = 218;
    PnlEmptyCenter.Margins.Left  = 6;
    PnlEmptyCenter.Margins.Right = 6;
    PnlEmptyCenter.Margins.Top   = 10;
    ImgEmpty.Margins.Top = 4;
    ImgEmpty.Height = 64;
    ImgEmpty.Width  = 64;
    LblEmptyTitle.Height = 30;
    LblEmptyTitle.Margins.Top = 10;
    LblEmptyTitle.clProSettings.FontSize = 14;
    LblEmptyTitle.clProSettings.WordWrap = True;
    LblEmptyTitle.clProSettings.FontVertAlign = palCenter;
    LblEmptyTitle.SetclProSettings(LblEmptyTitle.clProSettings);
    LblEmptySub.Height = 68;
    LblEmptySub.Margins.Top = 8;
    LblEmptySub.clProSettings.FontSize = 11;
    LblEmptySub.clProSettings.FontVertAlign = palCenter;
    LblEmptySub.SetclProSettings(LblEmptySub.clProSettings);

    PnlListHost.Margins.Top    = 0;
    PnlListHost.Margins.Bottom = 8;
  }
  else
  {
    sideM = 12;
    PnlBody.Margins.Left   = sideM;
    PnlBody.Margins.Right  = sideM;
    PnlBody.Margins.Top    = 12;
    PnlBody.Margins.Bottom = 12;

    LblSecili.Visible = True;
    LblSecili.Height = 40;
    LblSecili.Margins.Bottom = 16;

    bodyInnerW = FormY.clWidth - PnlBody.Margins.Left - PnlBody.Margins.Right;
    solW = 400;
    minSag = 300;
    if (bodyInnerW < solW + 12 + minSag)
    {
      solW = bodyInnerW - 12 - minSag;
      if (solW < 260)
      {
        solW = 260;
      }
    }

    PnlSol.Align = alLeft;
    PnlSol.Width = solW;
    PnlSol.Margins.Right = 12;
    PnlSol.Margins.Bottom = 0;

    PnlSag.Align = alClient;
    PnlSag.Margins.Top    = 0;
    PnlSag.Margins.Left   = 0;
    PnlSag.Margins.Right  = 0;
    PnlSag.Margins.Bottom = 0;

    PnlBody.Height = FormY.clHeight - 70 + C_SAFE_BOTTOM;
    if (PnlBody.Height < 580)
    {
      PnlBody.Height = 580;
    }

    BtnCikis.Width = 80;
    LblKullanici.Margins.Right = 100;
    LblKullanici.clProSettings.FontSize = 13;
    LblKullanici.SetclProSettings(LblKullanici.clProSettings);

    PnlSolToolbar.Height = 54;
    PnlSolToolbar.Margins.Left   = 16;
    PnlSolToolbar.Margins.Right  = 16;
    PnlSolToolbar.Margins.Top    = 0;
    PnlSolToolbar.Margins.Bottom = 8;
    PnlToolPrefix.Width = 104;
    BtnYenile.Width = 92;
    BtnYenile.clProSettings.FontSize = 14;
    BtnYenile.SetclProSettings(BtnYenile.clProSettings);

    PnlAraSutun.Width = 54;
    PnlAraSutun.Margins.Left = 0;
    PnlAraSutun.Margins.Top = 6;
    PnlAraSutun.Margins.Bottom = 6;
    PnlAraSutun.Margins.Right = 6;

    EdtTalepAra.Align = alClient;
    EdtTalepAra.Margins.Left = 8;
    EdtTalepAra.Margins.Right = 8;
    EdtTalepAra.Margins.Top = 8;
    EdtTalepAra.Margins.Bottom = 8;
    EdtTalepAra.Padding.Left = 10;
    EdtTalepAra.Padding.Right = 10;
    EdtTalepAra.Height = 38;
    EdtTalepAra.clProSettings.FontSize = 13;
    EdtTalepAra.SetclProSettings(EdtTalepAra.clProSettings);
    EdtTalepAra.TextPrompt = 'Ara: numara, baslik veya konum';

    BtnTalepAra.clProSettings.FontSize = 12;
    BtnTalepAra.clProSettings.TextSettings.Font.Style = [fsBold];
    BtnTalepAra.SetclProSettings(BtnTalepAra.clProSettings);

    BtnPersYenile.Width = 84;
    BtnPersYenile.Height = 40;
    BtnPersYenile.Margins.Top = 6;
    BtnPersYenile.Margins.Bottom = 6;
    BtnPersYenile.clProSettings.FontSize = 14;
    BtnPersYenile.SetclProSettings(BtnPersYenile.clProSettings);
    CmbPersonel.Margins.Top = 6;
    CmbPersonel.Margins.Bottom = 6;
    CmbPersonel.Margins.Right = 8;

    PnlPersRow.Height = 52;
    EdtNot.TextPrompt = 'Opsiyonel - kisa not';
    LbTalepler.clProSettings.ItemHeight = 132;
    LbTalepler.clProSettings.ItemSpace = 8;
    LbTalepler.SetclProSettings(LbTalepler.clProSettings);
    LvDesigner.Height = 120;
    LvDesigner.clProSettings.ItemHeight = 132;
    LvDesigner.SetclProSettings(LvDesigner.clProSettings);

    LblBaslik.Width = 220;

    PnlTalepTitleRow.Height = 36;
    LblTalepCount.Width = 86;
    LblTalepCount.Height = 32;
    LblTalepCount.clProSettings.FontSize = 10;
    LblTalepCount.SetclProSettings(LblTalepCount.clProSettings);
    LblTalepTitle.clProSettings.FontSize = 16;
    LblTalepTitle.SetclProSettings(LblTalepTitle.clProSettings);

    PnlEmptyState.Margins.Left   = 16;
    PnlEmptyState.Margins.Right  = 16;
    PnlEmptyState.Margins.Top    = 20;
    PnlEmptyState.Margins.Bottom = 20;
    PnlEmptyCenter.Height = 248;
    PnlEmptyCenter.Margins.Left  = 10;
    PnlEmptyCenter.Margins.Right = 10;
    PnlEmptyCenter.Margins.Top   = 12;
    ImgEmpty.Margins.Top = 8;
    ImgEmpty.Height = 88;
    ImgEmpty.Width  = 88;
    LblEmptyTitle.Height = 32;
    LblEmptyTitle.Margins.Top = 14;
    LblEmptyTitle.clProSettings.FontSize = 15;
    LblEmptyTitle.clProSettings.WordWrap = False;
    LblEmptyTitle.clProSettings.FontVertAlign = palCenter;
    LblEmptyTitle.SetclProSettings(LblEmptyTitle.clProSettings);
    LblEmptySub.Height = 76;
    LblEmptySub.Margins.Top = 10;
    LblEmptySub.clProSettings.FontSize = 12;
    LblEmptySub.clProSettings.FontVertAlign = palCenter;
    LblEmptySub.SetclProSettings(LblEmptySub.clProSettings);

    PnlListHost.Margins.Top    = 0;
    PnlListHost.Margins.Bottom = 8;
  }

  if (LvDesigner <> nil)
  {
    LvDesigner.Width = IMax(200, PnlSol.Width - 64);
    LvDesigner.SetclProSettings(LvDesigner.clProSettings);
  }
  TalepListeDesignerRenkYenile;

  LblMsgBoslukAyarla;
}

// Ilk frame sonrasi gercek FormY.clWidth ile yerlesimi bir kez duzelt (TRO: cagrilan prosedur once tanimlanmali).
void YerlesimLayoutTick;
{
  UygulaResponsiveYerlesim;
  TmrYerlesim.Enabled = False;
}


// ============================== [UI KURULUM] =================================

{
  try
    Adim = '1: FormY.Create';
    FormY = TclForm.Create(Self);
    Adim = '2: FormY.SetFormColor';
    FormY.SetFormColor(C_HEADER_BAR, C_BODY_END, clGVertical);
    Adim = '3: FormY.clsetCaption';
    FormY.clsetCaption('Yonetici - Atama');
    LastAcikTalepJson = '';

    Adim = '4: PnlHeader';
    PnlHeader = FormY.AddNewProPanel(FormY, 'PnlHeader');
    PnlHeader.Align  = alTop;
    PnlHeader.Height = 56;
    PnlHeader.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_HEADER_BAR);
    PnlHeader.SetclProSettings(PnlHeader.clProSettings);

    Adim = '5: LblBaslik';
    LblBaslik = FormY.AddNewProLabel(PnlHeader, 'LblBaslik', 'Yonetici - Atama');
    LblBaslik.Align  = alLeft;
    LblBaslik.Width  = 220;
    LblBaslik.Margins.Left = 16;
    LblBaslik.Margins.Top  = 12;
    LblBaslik.clProSettings.FontSize = 17;
    LblBaslik.clProSettings.TextSettings.Font.Style = [fsBold];
    LblBaslik.clProSettings.FontColor = clAlphaColor.clHexToColor(C_TEXT);
    LblBaslik.SetclProSettings(LblBaslik.clProSettings);

    Adim = '6: LblKullanici';
    LblKullanici = FormY.AddNewProLabel(PnlHeader, 'LblKullanici', '');
    LblKullanici.Visible = False;
    LblKullanici.Height = 0;
    LblKullanici.Align = alClient;
    LblKullanici.Margins.Right = 100;
    LblKullanici.Margins.Top  = 14;
    LblKullanici.clProSettings.FontColor = clAlphaColor.clHexToColor(C_MUTED);
    LblKullanici.clProSettings.FontHorzAlign = palTrailing;
    LblKullanici.SetclProSettings(LblKullanici.clProSettings);

    Adim = '7: BtnCikis';
    BtnCikis = FormY.AddNewProButton(PnlHeader, 'BtnCikis', 'Cikis');
    BtnCikis.Align = alRight;
    BtnCikis.Width = 80;
    BtnCikis.Height = 36;
    BtnCikis.Margins.Right = 12;
    BtnCikis.Margins.Top = 6;
    BtnCikis.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_DANGER_BG);
    BtnCikis.clProSettings.FontColor = clAlphaColor.clHexToColor(C_DANGER);
    BtnCikis.clProSettings.BorderColor = clAlphaColor.clHexToColor(C_DANGER);
    BtnCikis.clProSettings.BorderWidth = 1;
    BtnCikis.clProSettings.IsRound = True;
    BtnCikis.clProSettings.RoundHeight = 8;
    BtnCikis.clProSettings.RoundWidth = 8;
    BtnCikis.SetclProSettings(BtnCikis.clProSettings);
    FormY.AddNewEvent(BtnCikis, tbeOnClick, 'CikisClick');

    Adim = '8: PnlHeadSep';
    PnlHeadSep = FormY.AddNewProPanel(FormY, 'PnlHeadSep');
    PnlHeadSep.Align  = alTop;
    PnlHeadSep.Height = 1;
    PnlHeadSep.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_BORDER);
    PnlHeadSep.SetclProSettings(PnlHeadSep.clProSettings);

    Adim = '8c: VScroll';
    VScroll = FormY.AddNewVertScrollBox(FormY, 'VScroll');
    VScroll.Align = alClient;

    Adim = '9: PnlBody';
    PnlBody = FormY.AddNewProPanel(VScroll, 'PnlBody');
    PnlBody.Align = alTop;
    PnlBody.Height = FormY.clHeight - 70;
    if (PnlBody.Height < 580)
    {
      PnlBody.Height = 580;
    }
    PnlBody.Margins.Left   = 12;
    PnlBody.Margins.Right  = 12;
    PnlBody.Margins.Top    = 12;
    PnlBody.Margins.Bottom = 12;
    PnlBody.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_SURFACE);
    PnlBody.SetclProSettings(PnlBody.clProSettings);

    // --- SOL KART -------------------------------------------------------------
    Adim = '10: PnlSol';
    PnlSol = FormY.AddNewProPanel(PnlBody, 'PnlSol');
    PnlSol.Align = alLeft;
    PnlSol.Width = 400;
    PnlSol.Margins.Right = 12;
    PnlSol.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(C_CARD);
