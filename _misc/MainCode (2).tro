var
  MainForm: TclForm;
  PnlHeader, PnlHeaderLeft, PnlHeaderRight: TclProPanel;
  LblHeaderTitle, LblHeaderSub, LblStatusBadge: TclProLabel;
  LytLeftSimulator, LytRightCanvas: TclLayout;
  PnlPhoneBorder, PnlPhoneScreen: TclProPanel;
  PnlCanvasCard, PnlCanvasFooter: TclProPanel;
  LytAnaSayfa, LytIcerikOlustur, LytAIOniri, LytSablonYonet, LytIcerikListesi: TclLayout;
  LblAppTitle, LblAppUser: TclProLabel;
  BtnNavCreate, BtnNavList, BtnNavShare, BtnNavTemplates, BtnNavAISuggest, BtnNavHistory, BtnNavExit: TclProButton;
  LblScreen2Title: TclProLabel;
  EdtBaslik, EdtAciklama, EdtMarka, EdtTarih, EdtSaat, EdtGorselUrl: TclProEdit;
  BtnAIOneriyeGit, BtnAIGorselUret, BtnTaslakKaydet: TclProButton;
  LblScreen3Title, LblAIResultTitle: TclProLabel;
  EdtPromptText: TclProEdit;
  PnlAIResultBox: TclProPanel;
  LblAIResultContent: TclProLabel;
  BtnAIOneriAl, BtnOneriKullan, BtnOneriGeri: TclProButton;
  PnlCanvasHeader: TclProPanel;
  LblCanvasLogo, LblCanvasRatioMode: TclProLabel;
  ImgCanvasMain: TclImage;
  LblCanvasTitle, LblCanvasDesc, LblCanvasFooterText: TclProLabel;
  BtnRatioSquare, BtnRatioStory, BtnRatioFB, BtnDownloadGorsel, BtnShareGorsel: TclProButton;
  LytRatioGroup, LytActionGroup: TclLayout;

void EkranlariGizle;
{
  LytAnaSayfa.Visible = False;
  LytIcerikOlustur.Visible = False;
  LytAIOniri.Visible = False;
}

void GoToAnaSayfa; { EkranlariGizle; LytAnaSayfa.Visible = True; }
void GoToIcerikOlustur; { EkranlariGizle; LytIcerikOlustur.Visible = True; }
void GoToAIOniri; { EkranlariGizle; LytAIOniri.Visible = True; }

void FormVerileriniGuncelle;
{
  LblCanvasTitle.Text = EdtBaslik.Text;
  LblCanvasDesc.Text = EdtAciklama.Text;
  LblCanvasLogo.Text = EdtMarka.Text;
  if (EdtGorselUrl.Text <> '') 
  {
    MainForm.SetImage(ImgCanvasMain, EdtGorselUrl.Text);
  }
}

void SetRatioSquare;
{
  PnlCanvasCard.Width = 380;
  PnlCanvasCard.Height = 380;
  LblCanvasRatioMode.Text = 'POST (1:1)';
}

void SetRatioStory;
{
  PnlCanvasCard.Width = 260;
  PnlCanvasCard.Height = 440;
  LblCanvasRatioMode.Text = 'STORY (9:16)';
}

void SetRatioLandscape;
{
  PnlCanvasCard.Width = 440;
  PnlCanvasCard.Height = 250;
  LblCanvasRatioMode.Text = 'FEED (16:9)';
}

void ExecuteAIOneri;
{
  if (EdtPromptText.Text == '') 
  {
    ShowMessage('Lütfen bir komut giriniz!');
    Exit;
  }
  
  LblAIResultContent.Text = '🎯 Önerilen Başlık: Yaz Rüzgârı Başladı! ☀️' + #13 +
                            '📝 Açıklama: Sezonun en göz alıcı tasarımlarında %50 indirim fırsatı!' + #13 +
                            '🏷️ Marka: Aura Design';
  BtnOneriKullan.Visible = True;
}

void ApplyAIOneri;
{
  EdtBaslik.Text = 'Yaz Rüzgârı Başladı! ☀️';
  EdtAciklama.Text = 'Sezonun en göz alıcı tasarımlarında %50 indirim fırsatı!';
  EdtMarka.Text = 'Aura Design';
  EdtGorselUrl.Text = 'https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=800&q=80';
  FormVerileriniGuncelle;
  GoToIcerikOlustur;
}

void SimulateAIGorsel;
{
  EdtGorselUrl.Text = 'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=800&q=80';
  FormVerileriniGuncelle;
  ShowMessage('AI Görseli başarıyla üretildi ve Kanvasa yüklendi!');
}

void HeaderKurulum;
{
  PnlHeader = MainForm.AddNewProPanel(MainForm, 'PnlHeader');
  PnlHeader.Align = alTop; PnlHeader.Height = 70;
  clComponent.SetupComponent(PnlHeader, '{"BackgroundColor":"#1E293B", "BorderColor":"#334155", "BorderWidth":1}');

  PnlHeaderLeft = MainForm.AddNewProPanel(PnlHeader, 'PnlHeaderLeft');
  PnlHeaderLeft.Align = alLeft; PnlHeaderLeft.Width = 400;
  clComponent.SetupComponent(PnlHeaderLeft, '{"BackgroundColor":"#1E293B"}');

  LblHeaderTitle = MainForm.AddNewProLabel(PnlHeaderLeft, 'LblHeaderTitle', 'AI Sosyal Medya Otomasyonu');
  LblHeaderTitle.Align = alTop; LblHeaderTitle.Height = 35; LblHeaderTitle.Margins.Left = 20; LblHeaderTitle.Margins.Top = 10;
  LblHeaderTitle.clProSettings.FontSize = 16; LblHeaderTitle.clProSettings.FontColor = clAlphaColor.clWhite;
  LblHeaderTitle.clProSettings.TextSettings.Font.Style = [fsBold]; LblHeaderTitle.SetclProSettings(LblHeaderTitle.clProSettings);

  LblHeaderSub = MainForm.AddNewProLabel(PnlHeaderLeft, 'LblHeaderSub', 'Canlı Tasarım Ön İzlemeli UI / UX Workspace');
  LblHeaderSub.Align = alTop; LblHeaderSub.Height = 20; LblHeaderSub.Margins.Left = 20;
  LblHeaderSub.clProSettings.FontSize = 11; LblHeaderSub.clProSettings.FontColor = clAlphaColor.clHexToColor('#94A3B8');
  LblHeaderSub.SetclProSettings(LblHeaderSub.clProSettings);

  PnlHeaderRight = MainForm.AddNewProPanel(PnlHeader, 'PnlHeaderRight');
  PnlHeaderRight.Align = alRight; PnlHeaderRight.Width = 220;
  clComponent.SetupComponent(PnlHeaderRight, '{"BackgroundColor":"#1E293B"}');

  LblStatusBadge = MainForm.AddNewProLabel(PnlHeaderRight, 'LblStatusBadge', '🟢 Tasarım Modu: Aktif');
  LblStatusBadge.Align = alCenter; LblStatusBadge.Height = 35; LblStatusBadge.Width = 180;
  LblStatusBadge.clProSettings.FontSize = 12; LblStatusBadge.clProSettings.FontColor = clAlphaColor.clHexToColor('#10B981');
  LblStatusBadge.clProSettings.FontHorzAlign = palCenter; LblStatusBadge.clProSettings.FontVertAlign = palCenter;
  LblStatusBadge.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#064E3B');
  LblStatusBadge.clProSettings.RoundHeight = 15; LblStatusBadge.clProSettings.RoundWidth = 15;
  LblStatusBadge.SetclProSettings(LblStatusBadge.clProSettings);
}

