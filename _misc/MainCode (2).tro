void SagKanvasKurulum;
{
  LytRightCanvas = MainForm.AddNewLayout(MainForm, 'LytRightCanvas');
  LytRightCanvas.Align = alClient; LytRightCanvas.Margins.Left = 30; LytRightCanvas.Margins.Top = 15; LytRightCanvas.Margins.Right = 20;

  LytRatioGroup = MainForm.AddNewLayout(LytRightCanvas, 'LytRatioGroup');
  LytRatioGroup.Align = alTop; LytRatioGroup.Height = 45;

  BtnRatioSquare = MainForm.AddNewProButton(LytRatioGroup, 'BtnRatioSquare', '⏹️ KARE (1:1)');
  BtnRatioSquare.Align = alLeft; BtnRatioSquare.Width = 140;
  BtnRatioSquare.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#1E293B'); BtnRatioSquare.clProSettings.FontColor = clAlphaColor.clWhite;
  BtnRatioSquare.SetclProSettings(BtnRatioSquare.clProSettings);
  MainForm.AddNewEvent(BtnRatioSquare, tbeOnClick, 'SetRatioSquare');

  BtnRatioStory = MainForm.AddNewProButton(LytRatioGroup, 'BtnRatioStory', '📱 STORY (9:16)');
  BtnRatioStory.Align = alLeft; BtnRatioStory.Width = 140; BtnRatioStory.Margins.Left = 10;
  BtnRatioStory.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#1E293B'); BtnRatioStory.clProSettings.FontColor = clAlphaColor.clWhite;
  BtnRatioStory.SetclProSettings(BtnRatioStory.clProSettings);
  MainForm.AddNewEvent(BtnRatioStory, tbeOnClick, 'SetRatioStory');

  BtnRatioFB = MainForm.AddNewProButton(LytRatioGroup, 'BtnRatioFB', '🖥️ FEED (16:9)');
  BtnRatioFB.Align = alLeft; BtnRatioFB.Width = 140; BtnRatioFB.Margins.Left = 10;
  BtnRatioFB.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#1E293B'); BtnRatioFB.clProSettings.FontColor = clAlphaColor.clWhite;
  BtnRatioFB.SetclProSettings(BtnRatioFB.clProSettings);
  MainForm.AddNewEvent(BtnRatioFB, tbeOnClick, 'SetRatioLandscape');

  PnlCanvasCard = MainForm.AddNewProPanel(LytRightCanvas, 'PnlCanvasCard');
  PnlCanvasCard.Align = alCenter; PnlCanvasCard.Width = 380; PnlCanvasCard.Height = 380;
  clComponent.SetupComponent(PnlCanvasCard, '{"BackgroundColor":"#1E293B", "BorderColor":"#334155", "BorderWidth":1, "RoundHeight":15, "RoundWidth":15}');

  PnlCanvasHeader = MainForm.AddNewProPanel(PnlCanvasCard, 'PnlCanvasHeader');
  PnlCanvasHeader.Align = alTop; PnlCanvasHeader.Height = 45;
  clComponent.SetupComponent(PnlCanvasHeader, '{"BackgroundColor":"#1E293B"}');

  LblCanvasLogo = MainForm.AddNewProLabel(PnlCanvasHeader, 'LblCanvasLogo', 'Markanız');
  LblCanvasLogo.Align = alLeft; LblCanvasLogo.Width = 150; LblCanvasLogo.Margins.Left = 15;
  LblCanvasLogo.clProSettings.FontColor = clAlphaColor.clHexToColor('#10B981'); LblCanvasLogo.clProSettings.FontSize = 12;
  LblCanvasLogo.clProSettings.TextSettings.Font.Style = [fsBold]; LblCanvasLogo.SetclProSettings(LblCanvasLogo.clProSettings);

  LblCanvasRatioMode = MainForm.AddNewProLabel(PnlCanvasHeader, 'LblCanvasRatioMode', 'POST (1:1)');
  LblCanvasRatioMode.Align = alRight; LblCanvasRatioMode.Width = 100; LblCanvasRatioMode.Margins.Right = 15;
  LblCanvasRatioMode.clProSettings.FontColor = clAlphaColor.clHexToColor('#64748B'); 
  LblCanvasRatioMode.SetclProSettings(LblCanvasRatioMode.clProSettings);

  ImgCanvasMain = MainForm.AddNewImage(PnlCanvasCard, 'ImgCanvasMain');
  ImgCanvasMain.Align = alClient; ImgCanvasMain.Margins.Left = 15; ImgCanvasMain.Margins.Right = 15; ImgCanvasMain.Margins.Bottom = 10;

  LblCanvasTitle = MainForm.AddNewProLabel(PnlCanvasCard, 'LblCanvasTitle', 'Yeni Koleksiyon Keşfi');
  LblCanvasTitle.Align = alBottom; LblCanvasTitle.Height = 35; LblCanvasTitle.Margins.Left = 15; LblCanvasTitle.Margins.Right = 15;
  LblCanvasTitle.clProSettings.FontColor = clAlphaColor.clWhite; LblCanvasTitle.clProSettings.FontSize = 15;
  LblCanvasTitle.clProSettings.TextSettings.Font.Style = [fsBold]; LblCanvasTitle.SetclProSettings(LblCanvasTitle.clProSettings);

  LblCanvasDesc = MainForm.AddNewProLabel(PnlCanvasCard, 'LblCanvasDesc', 'Doğanın esintilerinden ilham alan benzersiz koleksiyonumuz şimdi yayında.');
  LblCanvasDesc.Align = alBottom; LblCanvasDesc.Height = 50; LblCanvasDesc.Margins.Left = 15; LblCanvasDesc.Margins.Right = 15; LblCanvasDesc.Margins.Bottom = 5;
  LblCanvasDesc.clProSettings.FontColor = clAlphaColor.clHexToColor('#94A3B8'); LblCanvasDesc.clProSettings.FontSize = 11;
  LblCanvasDesc.clProSettings.WordWrap = True; LblCanvasDesc.SetclProSettings(LblCanvasDesc.clProSettings);

  PnlCanvasFooter = MainForm.AddNewProPanel(PnlCanvasCard, 'PnlCanvasFooter');
  PnlCanvasFooter.Align = alBottom; PnlCanvasFooter.Height = 35;
  clComponent.SetupComponent(PnlCanvasFooter, '{"BackgroundColor":"#161E2E"}');

  LblCanvasFooterText = MainForm.AddNewProLabel(PnlCanvasFooter, 'LblCanvasFooterText', '✨ AI Tasarım Şablon Motoru');
  LblCanvasFooterText.Align = alClient; LblCanvasFooterText.Margins.Left = 15;
  LblCanvasFooterText.clProSettings.FontColor = clAlphaColor.clHexToColor('#64748B'); LblCanvasFooterText.clProSettings.FontSize = 10;
  LblCanvasFooterText.SetclProSettings(LblCanvasFooterText.clProSettings);

  LytActionGroup = MainForm.AddNewLayout(LytRightCanvas, 'LytActionGroup');
  LytActionGroup.Align = alBottom; LytActionGroup.Height = 50; LytActionGroup.Margins.Bottom = 20;

  BtnDownloadGorsel = MainForm.AddNewProButton(LytActionGroup, 'BtnDownloadGorsel', '💾 GÖRSELİ İNDİR');
  BtnDownloadGorsel.Align = alLeft; BtnDownloadGorsel.Width = 200;
  BtnDownloadGorsel.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#10B981'); BtnDownloadGorsel.clProSettings.FontColor = clAlphaColor.clWhite;
  BtnDownloadGorsel.clProSettings.RoundHeight = 8; BtnDownloadGorsel.SetclProSettings(BtnDownloadGorsel.clProSettings);
  MainForm.AddNewEvent(BtnDownloadGorsel, tbeOnClick, 'ShowMessage("Görsel Atayüz galerinize indirildi!")');

  BtnShareGorsel = MainForm.AddNewProButton(LytActionGroup, 'BtnShareGorsel', '📤 ANINDA PAYLAŞ');
  BtnShareGorsel.Align = alClient; BtnShareGorsel.Margins.Left = 15;
  BtnShareGorsel.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#0EA5E9'); BtnShareGorsel.clProSettings.FontColor = clAlphaColor.clWhite;
  BtnShareGorsel.clProSettings.RoundHeight = 8; BtnShareGorsel.SetclProSettings(BtnShareGorsel.clProSettings);
  MainForm.AddNewEvent(BtnShareGorsel, tbeOnClick, 'ShowMessage("Meta Graph API entegrasyonu ile yayına gönderildi!")');
}

{
  MainForm = TclForm.Create(Self);
  MainForm.LytTopBar.Visible = False;
  MainForm.SetFormColor('#0F172A', '#0F172A', clGNone);

  HeaderKurulum;
  SolSimulatorKurulum;
  SagKanvasKurulum;

