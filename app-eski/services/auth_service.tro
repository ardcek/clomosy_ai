unit auth_service;

interface

uses firebase_service;

function Login(const Email: String; const Password: String): String;

implementation

function Login(const Email: String; const Password: String): String;
var
  Body : String;
begin
  Body := '{' +
          '"email":"' + Email + '",' +
          '"password":"' + Password + '"' +
          '}';
  Result := ApiPost('/login', Body, '');
end;

end.
