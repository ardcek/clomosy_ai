rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol;
    }

    function isManager() {
      return isSignedIn() && userRole() == 'Yonetici';
    }

    function isRequester() {
      return isSignedIn() && userRole() == 'TalepAcan';
    }

    function isFieldWorker() {
      return isSignedIn() && userRole() == 'SahaPersoneli';
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isManager());
      allow write: if isManager();
    }

    match /tickets/{ticketId} {
      allow create: if isRequester();
      allow read: if isManager()
                  || (isRequester() && resource.data.talepAcanId == request.auth.uid)
                  || (isFieldWorker() && resource.data.atananPersonelId == request.auth.uid);
      allow update: if isManager()
                    || (isFieldWorker() && resource.data.atananPersonelId == request.auth.uid);
      allow delete: if false;

      match /events/{eventId} {
        allow read: if isManager()
                    || (isRequester() && get(/databases/$(database)/documents/tickets/$(ticketId)).data.talepAcanId == request.auth.uid)
                    || (isFieldWorker() && get(/databases/$(database)/documents/tickets/$(ticketId)).data.atananPersonelId == request.auth.uid);
        allow create: if isManager() || isFieldWorker() || isRequester();
        allow update, delete: if false;
      }
    }
  }
}
